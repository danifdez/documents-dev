#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# ── Colors ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }
step()  { printf "\n${BOLD}${CYAN}── %s ──${NC}\n" "$*"; }

APP_VERSION="1.0.0"
RELEASE_DIR="$ROOT_DIR/release-assets"

# ── Detect platform and architecture ──
detect_platform() {
  local os arch
  case "$(uname -s)" in
    Linux*)  os="linux" ;;
    Darwin*) os="darwin" ;;
    MINGW*|MSYS*|CYGWIN*) os="win32" ;;
    *) fail "Unsupported OS: $(uname -s)" ;;
  esac
  case "$(uname -m)" in
    x86_64|amd64) arch="x64" ;;
    aarch64|arm64) arch="arm64" ;;
    *) fail "Unsupported architecture: $(uname -m)" ;;
  esac
  echo "${os}-${arch}"
}

PLATFORM="$(detect_platform)"
info "Detected platform: $PLATFORM"

archive_ext() {
  [ "$PLATFORM" = "win32-x64" ] && echo "zip" || echo "tar.gz"
}

# ════════════════════════════════════════════════════════════════════
# BUILD BACKEND RELEASE ASSET
# ════════════════════════════════════════════════════════════════════
build_backend() {
  step "Building backend release asset"

  cd "$ROOT_DIR/backend"

  info "Installing backend dependencies..."
  npm ci --quiet 2>&1 | tail -3
  ok "Dependencies installed"

  info "Compiling TypeScript..."
  npm run build --quiet
  ok "Backend compiled"

  local staging="$ROOT_DIR/.build-staging/backend"
  rm -rf "$staging"
  mkdir -p "$staging"

  cp -r dist "$staging/dist"
  cp package.json "$staging/package.json"
  cp package-lock.json "$staging/package-lock.json" 2>/dev/null || true

  info "Installing production dependencies..."
  cd "$staging"
  npm ci --omit=dev --quiet 2>&1 | tail -3

  mkdir -p "$RELEASE_DIR"
  local name="documents-backend-v${APP_VERSION}-${PLATFORM}"
  cd "$ROOT_DIR/.build-staging"
  if [ "$(archive_ext)" = "zip" ]; then
    zip -qr "$RELEASE_DIR/${name}.zip" backend
  else
    tar czf "$RELEASE_DIR/${name}.tar.gz" backend
  fi

  rm -rf "$ROOT_DIR/.build-staging/backend"
  ok "Backend asset: $RELEASE_DIR/${name}.$(archive_ext) ($(du -sh "$RELEASE_DIR/${name}."* | cut -f1))"
  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# BUILD ELECTRON INSTALLER (frontend only, lightweight)
# ════════════════════════════════════════════════════════════════════
build_installer() {
  step "Building Electron installer (frontend only)"

  cd "$ROOT_DIR/frontend"

  info "Installing frontend dependencies..."
  npm ci --quiet 2>&1 | tail -3
  ok "Dependencies installed"

  info "Building Electron app..."
  npm run make 2>&1 | tail -20

  echo ""
  ok "Installer build complete!"

  if [ -d "out/make" ]; then
    info "Installers:"
    find out/make -type f \( -name "*.deb" -o -name "*.rpm" -o -name "*.exe" -o -name "*.zip" -o -name "*.dmg" -o -name "*.AppImage" \) | while read -r f; do
      printf "  ${GREEN}→${NC} %s ${DIM}(%s)${NC}\n" "$f" "$(du -sh "$f" | cut -f1)"
    done
  fi

  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# BUILD MODELS SERVICE (PyInstaller)
# ════════════════════════════════════════════════════════════════════
build_models() {
  local variant="${1:-cpu}"
  step "Building models service (${variant})"

  cd "$ROOT_DIR/models"

  if ! command -v pyinstaller >/dev/null 2>&1; then
    info "Installing PyInstaller..."
    pip install pyinstaller --quiet
  fi

  [ -f "jobs.py" ] || fail "models/jobs.py not found"

  info "Bundling Python + dependencies (this takes a while)..."

  pyinstaller \
    --name documents-models \
    --onedir \
    --noconfirm \
    --collect-all transformers \
    --collect-all sentence_transformers \
    --collect-all faster_whisper \
    --collect-all spacy \
    --collect-all llama_cpp \
    --collect-all docling \
    --collect-all diffusers \
    --hidden-import=tiktoken_ext.openai_public \
    --hidden-import=tiktoken_ext \
    jobs.py

  ok "Models service built"

  info "Adding spaCy model..."
  python -m spacy download en_core_web_sm --quiet 2>/dev/null || true
  local spacy_path
  spacy_path="$(python -c "import en_core_web_sm; print(en_core_web_sm.__path__[0])" 2>/dev/null || true)"
  if [ -n "$spacy_path" ] && [ -d "$spacy_path" ]; then
    cp -r "$spacy_path" dist/documents-models/en_core_web_sm
    ok "spaCy en_core_web_sm included"
  fi

  mkdir -p "$RELEASE_DIR"
  local name="documents-models-v${APP_VERSION}-${PLATFORM}-${variant}"
  if [ "$(archive_ext)" = "zip" ]; then
    cd dist && zip -qr "$RELEASE_DIR/${name}.zip" documents-models && cd ..
  else
    tar czf "$RELEASE_DIR/${name}.tar.gz" -C dist documents-models
  fi
  ok "Models asset: $RELEASE_DIR/${name}.$(archive_ext) ($(du -sh "$RELEASE_DIR/${name}."* | cut -f1))"

  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# CLEAN
# ════════════════════════════════════════════════════════════════════
clean() {
  step "Cleaning build artifacts"
  rm -rf "$ROOT_DIR/.build-staging"
  rm -rf "$ROOT_DIR/release-assets"
  rm -rf "$ROOT_DIR/frontend/out"
  rm -rf "$ROOT_DIR/backend/dist"
  rm -rf "$ROOT_DIR/models/dist"
  rm -rf "$ROOT_DIR/models/build"
  ok "Clean"
}

# ════════════════════════════════════════════════════════════════════
# HELP
# ════════════════════════════════════════════════════════════════════
show_help() {
  cat <<EOF

${BOLD}Documents Build${NC}

Builds the Electron installer and the release assets for standalone mode.
Databases (PostgreSQL, Qdrant, Neo4j) are downloaded by the app directly
from their official sources — they are NOT packaged here.

${BOLD}Usage:${NC}
  ./build-standalone [command]

${BOLD}Commands:${NC}
  ${GREEN}all${NC}             Build backend asset + Electron installer
  ${GREEN}installer${NC}       Build only the Electron app installer (~150 MB)
  ${GREEN}backend${NC}         Build the backend release asset (~50 MB)
  ${GREEN}models-cpu${NC}      Build the models service for CPU (~2 GB)
  ${GREEN}models-gpu${NC}      Build the models service for GPU/CUDA (~5 GB)
  ${GREEN}clean${NC}           Remove all build artifacts
  ${GREEN}help${NC}            Show this help

${BOLD}Workflow:${NC}
  1. ./build-standalone backend       # Build backend asset
  2. Upload release-assets/ to GitHub Releases
  3. ./build-standalone installer     # Build the lightweight installer
  4. Distribute the installer

${BOLD}What the app downloads at runtime (from official sources):${NC}
  PostgreSQL     ~200 MB   from repo1.maven.org (zonky binaries)
  Qdrant         ~40 MB    from github.com/qdrant/qdrant/releases
  Neo4j          ~60 MB    from dist.neo4j.org

${BOLD}What we host on GitHub Releases:${NC}
  Backend        ~50 MB    compiled NestJS + node_modules
  Models (CPU)   ~2 GB     PyInstaller bundle (optional)
  Models (GPU)   ~5 GB     PyInstaller bundle with CUDA (optional)

${BOLD}Output:${NC}
  frontend/out/make/        Platform installer
  release-assets/           Assets for GitHub Releases

${BOLD}Platform:${NC} $PLATFORM

EOF
}

# ════════════════════════════════════════════════════════════════════
# MAIN
# ════════════════════════════════════════════════════════════════════
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  all)
    echo ""
    printf "${BOLD}${CYAN}════════════════════════════════════════${NC}\n"
    printf "${BOLD}${CYAN}  Documents Build — ${PLATFORM}${NC}\n"
    printf "${BOLD}${CYAN}════════════════════════════════════════${NC}\n"
    build_backend
    build_installer
    echo ""
    printf "${BOLD}${GREEN}Build complete!${NC}\n"
    info "Release assets: release-assets/"
    info "Installer:      frontend/out/make/"
    ;;
  installer)    build_installer ;;
  backend)      build_backend ;;
  models-cpu)   build_models cpu ;;
  models-gpu)   build_models gpu ;;
  clean)
    clean
    if [ "${1:-}" = "all" ]; then
      shift || true
      exec "$0" all "$@"
    fi
    ;;
  help|--help|-h) show_help ;;
  *) fail "Unknown command: $COMMAND. Run '$0 help' for usage." ;;
esac
