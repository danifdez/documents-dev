#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# ── Colors ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }
step()  { printf "\n${BOLD}${CYAN}── %s ──${NC}\n" "$*"; }

APP_VERSION="1.0.0"
RELEASE_DIR="$ROOT_DIR/release-assets"

# ── Detect platform and architecture ──
detect_platform() {
  local os arch
  case "$(uname -s)" in
    Linux*)  os="linux" ;;
    Darwin*) os="darwin" ;;
    MINGW*|MSYS*|CYGWIN*) os="win32" ;;
    *) fail "Unsupported OS: $(uname -s)" ;;
  esac
  case "$(uname -m)" in
    x86_64|amd64) arch="x64" ;;
    aarch64|arm64) arch="arm64" ;;
    *) fail "Unsupported architecture: $(uname -m)" ;;
  esac
  echo "${os}-${arch}"
}

PLATFORM="$(detect_platform)"
info "Detected platform: $PLATFORM"

# Determine Electron version used by the frontend so we can rebuild native
# modules for the Electron runtime when packaging the backend. Falls back to
# empty string if not found.
ELECTRON_VERSION="$(node -e 'try{const p=require("./frontend/package.json"); console.log(p.dependencies?.electron||p.devDependencies?.electron||p.electron||"")}catch(e){console.log("")}' 2>/dev/null || true)"

archive_ext() {
  [ "$PLATFORM" = "win32-x64" ] && echo "zip" || echo "tar.gz"
}

# ════════════════════════════════════════════════════════════════════
# BUILD BACKEND RELEASE ASSET
# ════════════════════════════════════════════════════════════════════
build_backend() {
  step "Building backend release asset"

  cd "$ROOT_DIR/backend"

  info "Installing backend dependencies..."
  npm ci --quiet 2>&1 | tail -3
  ok "Dependencies installed"

  info "Compiling TypeScript..."
  npm run build --quiet
  ok "Backend compiled"

  local staging="$ROOT_DIR/.build-staging/backend"
  rm -rf "$staging"
  mkdir -p "$staging"

  cp -r dist "$staging/dist"
  # Seed files (e.g. resource-type.csv) are read at runtime by migrations but
  # aren't compiled into dist. Ship them at dist/data so the migration's
  # __dirname/../data lookup resolves regardless of the process cwd.
  [ -d data ] && cp -r data "$staging/dist/data"
  cp package.json "$staging/package.json"
  cp package-lock.json "$staging/package-lock.json" 2>/dev/null || true

  info "Installing production dependencies..."
  cd "$staging"
  npm ci --omit=dev --quiet 2>&1 | tail -3

  # If we know the frontend Electron version, try to rebuild native modules
  # against Electron's ABI so the packaged backend works when forked from the
  # Electron process at runtime.
  if [ -n "$ELECTRON_VERSION" ]; then
    info "Electron version detected: $ELECTRON_VERSION — rebuilding native modules for Electron"
    # install electron-rebuild temporarily
    npm i --no-audit --no-fund electron-rebuild@latest --silent 2>/dev/null || true
    npx electron-rebuild -v "$ELECTRON_VERSION" --module-dir . || warn "electron-rebuild failed; native modules may be incompatible"
  else
    warn "Electron version not detected — skipping electron-rebuild"
  fi

  mkdir -p "$RELEASE_DIR"
  local name="documents-backend-v${APP_VERSION}-${PLATFORM}"
  # Archive the contents of backend/ (not the dir itself) so the app extracts
  # straight into standalone-services/backend/ without a doubled prefix.
  cd "$ROOT_DIR/.build-staging/backend"
  if [ "$(archive_ext)" = "zip" ]; then
    zip -qr "$RELEASE_DIR/${name}.zip" .
  else
    tar czf "$RELEASE_DIR/${name}.tar.gz" .
  fi

  rm -rf "$ROOT_DIR/.build-staging/backend"
  ok "Backend asset: $RELEASE_DIR/${name}.$(archive_ext) ($(du -sh "$RELEASE_DIR/${name}."* | cut -f1))"
  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# BUILD ELECTRON INSTALLER (frontend only, lightweight)
# ════════════════════════════════════════════════════════════════════
build_installer() {
  step "Building Electron installer (frontend only)"

  cd "$ROOT_DIR/frontend"

  info "Installing frontend dependencies..."
  npm ci --quiet 2>&1 | tail -3
  ok "Dependencies installed"

  info "Building Electron app..."
  npm run make 2>&1 | tail -20

  echo ""
  ok "Installer build complete!"

  if [ -d "out/make" ]; then
    info "Installers:"
    find out/make -type f \( -name "*.deb" -o -name "*.rpm" -o -name "*.exe" -o -name "*.zip" -o -name "*.dmg" -o -name "*.AppImage" \) | while read -r f; do
      printf "  ${GREEN}→${NC} %s ${DIM}(%s)${NC}\n" "$f" "$(du -sh "$f" | cut -f1)"
    done
  fi

  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# BUILD MODELS SERVICE (PyInstaller)
# ════════════════════════════════════════════════════════════════════
build_models() {
  local variant="${1:-cpu}"
  step "Building models service (${variant})"

  cd "$ROOT_DIR/models"

  [ -f "jobs.py" ] || fail "models/jobs.py not found"

  # Each variant builds in its OWN venv with its OWN deps. CPU and CUDA builds of
  # torch/llama-cpp-python can't coexist in one environment, so the variant must
  # decide what gets installed — not just the asset name.
  local venv="$ROOT_DIR/.build-staging/venv-models-${variant}"
  info "Creating isolated build venv (${variant})..."
  rm -rf "$venv"
  python3 -m venv "$venv"
  if [ -f "$venv/bin/activate" ]; then
    # shellcheck disable=SC1091
    source "$venv/bin/activate"
  else
    # shellcheck disable=SC1091
    source "$venv/Scripts/activate"  # Windows (MSYS/Git-Bash)
  fi

  info "Installing ${variant} dependencies (downloads several GB)..."
  pip install --quiet --upgrade pip
  if [ "$variant" = "gpu" ]; then
    # GPU wheels first (CUDA torch + cupy via their extra-index-url), then the
    # rest; requirements.txt sees torch/llama-cpp already satisfied and won't pull
    # the CPU builds over them.
    pip install --quiet -r requirements-gpu.txt
    # llama-cpp-python: the abetlen cu126 prebuilt index has no wheel for current
    # Python, so any pip index resolution silently lands on the CPU wheel from
    # PyPI (then the LLM runs on CPU — no libggml-cuda.so bundled). Compile it
    # from source with CUDA instead. Requires nvcc + cmake + CUDA dev libs
    # (libcublas/libcudart) on the build host.
    command -v nvcc >/dev/null 2>&1 || fail "gpu build needs nvcc (CUDA toolkit) to compile llama-cpp-python with CUDA"
    CMAKE_ARGS="-DGGML_CUDA=on" pip install --quiet --no-binary llama-cpp-python --no-cache-dir llama-cpp-python
  fi
  pip install --quiet -r requirements.txt
  pip install --quiet pyinstaller

  # Install the spaCy model as a real wheel BEFORE bundling so PyInstaller can
  # collect both its code AND its dist-info metadata. spacy.load("en_core_web_sm")
  # resolves the model via importlib.metadata (is_package), so without the
  # metadata the frozen worker fails to load it and falls back to a network
  # `pip/uv install` — which has no pip in the bundle and no venv for uv, aborting
  # `--setup` with a SystemExit. Bundling the metadata makes load-by-name work.
  info "Installing spaCy model into build venv..."
  python -m spacy download en_core_web_sm --quiet 2>/dev/null || true

  info "Bundling Python + dependencies (this takes a while)..."

  # Task handlers are imported by convention at runtime (tasks/<type>/<type>.py),
  # so PyInstaller can't see them statically — collect them explicitly. Bundle
  # the config defaults, task configs and prompt.md files as data so the frozen
  # worker can read them from sys._MEIPASS.
  pyinstaller \
    --name documents-models \
    --onedir \
    --noconfirm \
    --collect-all transformers \
    --collect-all sentence_transformers \
    --collect-all huggingface_hub \
    --collect-all faster_whisper \
    --collect-all spacy \
    --collect-all en_core_web_sm \
    --copy-metadata en_core_web_sm \
    --collect-all llama_cpp \
    --collect-all docling \
    --collect-submodules tasks \
    --add-data "common:common" \
    --add-data "config:config" \
    --add-data "tasks:tasks" \
    --hidden-import=tiktoken_ext.openai_public \
    --hidden-import=tiktoken_ext \
    jobs.py

  ok "Models service built (spaCy model + metadata bundled in-place)"

  mkdir -p "$RELEASE_DIR"
  local name="documents-models-v${APP_VERSION}-${PLATFORM}-${variant}"
  # Archive the CONTENTS of the onedir bundle (not the dir itself) so the app
  # extracts the binary straight into models-service/ without a doubled prefix
  # (otherwise models-service/documents-models is a dir and spawn() gets EACCES).
  if [ "$(archive_ext)" = "zip" ]; then
    ( cd dist/documents-models && zip -qr "$RELEASE_DIR/${name}.zip" . )
  else
    tar czf "$RELEASE_DIR/${name}.tar.gz" -C dist/documents-models .
  fi
  ok "Models asset: $RELEASE_DIR/${name}.$(archive_ext) ($(du -sh "$RELEASE_DIR/${name}."* | cut -f1))"

  deactivate || true
  cd "$ROOT_DIR"
}

# ════════════════════════════════════════════════════════════════════
# CLEAN
# ════════════════════════════════════════════════════════════════════
clean() {
  step "Cleaning build artifacts"
  rm -rf "$ROOT_DIR/.build-staging"
  rm -rf "$ROOT_DIR/release-assets"
  rm -rf "$ROOT_DIR/frontend/out"
  rm -rf "$ROOT_DIR/backend/dist"
  rm -rf "$ROOT_DIR/models/dist"
  rm -rf "$ROOT_DIR/models/build"
  ok "Clean"
}

# ════════════════════════════════════════════════════════════════════
# SERVE LOCALLY (stand in for GitHub Releases)
# ════════════════════════════════════════════════════════════════════
serve_local() {
  local port="${1:-8000}"
  step "Serving release-assets as a local release server"

  [ -d "$RELEASE_DIR" ] || fail "No release-assets/. Build first (e.g. ./build-release backend && ./build-release models-cpu)."

  # The app requests \$BASE/v1.0.0/<asset>; expose the assets under that tag dir
  # via symlinks so the existing flat release-assets/ keeps working too.
  local tag="v${APP_VERSION}"
  local tagdir="$RELEASE_DIR/$tag"
  mkdir -p "$tagdir"
  shopt -s nullglob
  for f in "$RELEASE_DIR"/*.tar.gz "$RELEASE_DIR"/*.zip; do
    ln -sf "../$(basename "$f")" "$tagdir/$(basename "$f")"
  done
  shopt -u nullglob

  info "Assets available under $tag/:"
  ls -1 "$tagdir" 2>/dev/null | sed 's/^/  /' || warn "  (none — build the assets first)"
  echo ""
  ok "Launch the app pointing at this server:"
  printf "  ${BOLD}DOCUMENTS_RELEASE_BASE_URL=http://localhost:%s npm start${NC}  ${DIM}(run in frontend/)${NC}\n\n" "$port"
  info "Serving on http://localhost:$port — Ctrl-C to stop"
  cd "$RELEASE_DIR"
  python3 -m http.server "$port"
}

# ════════════════════════════════════════════════════════════════════
# HELP
# ════════════════════════════════════════════════════════════════════
show_help() {
  cat <<EOF

${BOLD}Documents Build${NC}

Builds the Electron installer and the release assets for standalone mode.
Databases (PostgreSQL, Qdrant, Neo4j) are downloaded by the app directly
from their official sources — they are NOT packaged here.

${BOLD}Usage:${NC}
  ./build-release [command]

${BOLD}Commands:${NC}
  ${GREEN}all${NC}             Build backend asset + Electron installer
  ${GREEN}installer${NC}       Build only the Electron app installer (~150 MB)
  ${GREEN}backend${NC}         Build the backend release asset (~50 MB)
  ${GREEN}models-cpu${NC}      Build the models service for CPU (~2 GB)
  ${GREEN}models-gpu${NC}      Build the models service for GPU/CUDA (~5 GB)
  ${GREEN}models-all${NC}      Build both CPU and GPU variants
  ${GREEN}serve [port]${NC}    Serve release-assets/ locally as a stand-in for GitHub
                  Releases (default port 8000)
  ${GREEN}clean${NC}           Remove all build artifacts
  ${GREEN}help${NC}            Show this help

${BOLD}Test standalone locally (without GitHub):${NC}
  1. ./build-release backend           # ~50 MB, quick
  2. ./build-release models-cpu         # ~2 GB, slow (downloads deps)
  3. ./build-release serve              # serves release-assets/ on :8000
  4. cd frontend && DOCUMENTS_RELEASE_BASE_URL=http://localhost:8000 npm start
     (DBs still come from their official sources — needs internet)

${BOLD}Covering "any machine":${NC}
  Each models variant builds in its own venv with its own deps (CPU vs CUDA).
  The wizard detects the user's GPU at runtime and downloads the right one.
  ${YELLOW}Limits:${NC} PyInstaller does NOT cross-compile — run this script once per OS
  (Linux/Windows/macOS) to cover them. The GPU variant needs the CUDA wheels
  reachable (build host needs internet; a physical GPU is not required to build).

${BOLD}Workflow:${NC}
  1. ./build-release backend       # Build backend asset
  2. Upload release-assets/ to GitHub Releases
  3. ./build-release installer     # Build the lightweight installer
  4. Distribute the installer

${BOLD}What the app downloads at runtime (from official sources):${NC}
  PostgreSQL     ~200 MB   from repo1.maven.org (zonky binaries)
  Qdrant         ~40 MB    from github.com/qdrant/qdrant/releases
  Neo4j          ~60 MB    from dist.neo4j.org

${BOLD}What we host on GitHub Releases:${NC}
  Backend        ~50 MB    compiled NestJS + node_modules
  Models (CPU)   ~2 GB     PyInstaller bundle (optional)
  Models (GPU)   ~5 GB     PyInstaller bundle with CUDA (optional)

${BOLD}Output:${NC}
  frontend/out/make/        Platform installer
  release-assets/           Assets for GitHub Releases

${BOLD}Platform:${NC} $PLATFORM

EOF
}

# ════════════════════════════════════════════════════════════════════
# MAIN
# ════════════════════════════════════════════════════════════════════
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  all)
    echo ""
    printf "${BOLD}${CYAN}════════════════════════════════════════${NC}\n"
    printf "${BOLD}${CYAN}  Documents Build — ${PLATFORM}${NC}\n"
    printf "${BOLD}${CYAN}════════════════════════════════════════${NC}\n"
    build_backend
    build_installer
    echo ""
    printf "${BOLD}${GREEN}Build complete!${NC}\n"
    info "Release assets: release-assets/"
    info "Installer:      frontend/out/make/"
    ;;
  installer)    build_installer ;;
  backend)      build_backend ;;
  models-cpu)   build_models cpu ;;
  models-gpu)   build_models gpu ;;
  models-all)   build_models cpu; build_models gpu ;;
  serve)        serve_local "${1:-8000}" ;;
  clean)
    clean
    if [ "${1:-}" = "all" ]; then
      shift || true
      exec "$0" all "$@"
    fi
    ;;
  help|--help|-h) show_help ;;
  *) fail "Unknown command: $COMMAND. Run '$0 help' for usage." ;;
esac
