  tail -f "$LOGFILE"
}

# ════════════════════════════════════════════════════════════════════
# EXPORT
# ════════════════════════════════════════════════════════════════════
cmd_export() {
  local OUTPUT_FILE="${1:-}"
  local TIMESTAMP
  TIMESTAMP="$(date +%Y%m%d_%H%M%S)"

  if [ -z "$OUTPUT_FILE" ]; then
    OUTPUT_FILE="$ROOT_DIR/backup_${TIMESTAMP}.tar.gz"
  fi

  case "$OUTPUT_FILE" in
    /*) ;;
    *) OUTPUT_FILE="$ROOT_DIR/$OUTPUT_FILE" ;;
  esac

  load_env
  ensure_profiles_initialized
  export_compose_project
  info "Starting export (profile: $(get_active_profile))..."

  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT

  # ── Dump PostgreSQL ──
  info "Dumping PostgreSQL database..."
  PGPASSWORD="${POSTGRES_PASSWORD:-example}" pg_dump -h localhost -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" --clean --if-exists > "$TMPDIR/database.sql"
  ok "Database dump complete"

  # ── Copy documents (dereference the symlink to grab real files) ──
  if [ -e "$ROOT_DIR/documents" ] && [ "$(ls -A "$ROOT_DIR/documents" 2>/dev/null)" ]; then
    info "Copying documents folder..."
    mkdir -p "$TMPDIR/documents"
    (cd "$ROOT_DIR/documents" && tar cf - .) | (cd "$TMPDIR/documents" && tar xf -)
    ok "Documents copied"
  else
    mkdir -p "$TMPDIR/documents"
  fi

  # ── Copy archived documents ──
  mkdir -p "$TMPDIR/documents-archive"
  if archive_dir_is_in_profile "$(get_active_profile)" && [ -e "$ROOT_DIR/documents-archive" ] && [ "$(ls -A "$ROOT_DIR/documents-archive" 2>/dev/null)" ]; then
    info "Copying archived documents folder..."
    (cd "$ROOT_DIR/documents-archive" && tar cf - .) | (cd "$TMPDIR/documents-archive" && tar xf -)
    ok "Archived documents copied"
  elif ! archive_dir_is_in_profile "$(get_active_profile)"; then
    warn "DOCUMENTS_ARCHIVE_DIR is set to an external path; archived files are NOT included in the export."
  fi

  # ── Metadata ──
  cat > "$TMPDIR/backup_metadata.json" <<METAEOF
{
  "created_at": "$(date -Iseconds)",
  "hostname": "$(hostname)",
  "user": "$(whoami)"
}
METAEOF

  # ── Compress ──
  info "Compressing backup..."
  tar -czf "$OUTPUT_FILE" -C "$TMPDIR" database.sql documents documents-archive backup_metadata.json

  ok "Export complete: $OUTPUT_FILE ($(du -h "$OUTPUT_FILE" | cut -f1))"
}

# ════════════════════════════════════════════════════════════════════
# IMPORT
# ════════════════════════════════════════════════════════════════════
cmd_import() {
  local INPUT_FILE="${1:-}"

  if [ -z "$INPUT_FILE" ]; then
    fail "Usage: $0 import <backup_file.tar.gz>"
  fi

  case "$INPUT_FILE" in
    /*) ;;
    *) INPUT_FILE="$(pwd)/$INPUT_FILE" ;;
  esac

  [ -f "$INPUT_FILE" ] || fail "File not found: $INPUT_FILE"

  echo "This will REPLACE the current database and documents with the contents of:"
  echo "  $INPUT_FILE"
  read -p "Type IMPORT to continue: " confirm
  if [ "$confirm" != "IMPORT" ]; then
    echo "Aborted."
    exit 1
  fi

  detect_compose
  load_env
  ensure_profiles_initialized
  export_compose_project
  info "Starting import into profile: $(get_active_profile)"

  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT

  info "Extracting backup..."
  tar -xzf "$INPUT_FILE" -C "$TMPDIR"

  [ -f "$TMPDIR/database.sql" ] || fail "Invalid backup: database.sql not found"
  [ -d "$TMPDIR/documents" ]    || fail "Invalid backup: documents/ not found"

  # ── Ensure infrastructure is running ──
  $COMPOSE_CMD up -d
  wait_for_postgres 30

  # ── Stop local services ──
  cmd_stop 2>/dev/null || true
  $COMPOSE_CMD up -d

  # ── Restore PostgreSQL ──
  info "Restoring PostgreSQL database..."
  $COMPOSE_CMD exec -T database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"
  $COMPOSE_CMD exec -T database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" < "$TMPDIR/database.sql"
  ok "Database restored"

  # ── Restore documents (into the active profile's real directory) ──
  info "Restoring documents folder..."
  local docs_target="$PROFILES_DIR/$(get_active_profile)/documents"
  mkdir -p "$docs_target"
  rm -rf "$docs_target"/* 2>/dev/null || true
  find "$docs_target" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
  if [ "$(ls -A "$TMPDIR/documents" 2>/dev/null)" ]; then
    (cd "$TMPDIR/documents" && tar cf - .) | (cd "$docs_target" && tar xf -)
  fi
  ok "Documents restored"

  # ── Restore archived documents (skip silently if backup has none or archive dir is external) ──
  if [ -d "$TMPDIR/documents-archive" ] && [ "$(ls -A "$TMPDIR/documents-archive" 2>/dev/null)" ]; then
    if archive_dir_is_in_profile "$(get_active_profile)"; then
      info "Restoring archived documents folder..."
      local archive_target="$PROFILES_DIR/$(get_active_profile)/documents-archive"
      mkdir -p "$archive_target"
      rm -rf "$archive_target"/* 2>/dev/null || true
      find "$archive_target" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
      (cd "$TMPDIR/documents-archive" && tar cf - .) | (cd "$archive_target" && tar xf -)
      ok "Archived documents restored"
    else
      warn "Backup contains archived documents but DOCUMENTS_ARCHIVE_DIR is external; skipping. Move them manually if needed."
    fi
  fi

  ok "Import complete. Run 'bash manage.sh start' to start services."
}

