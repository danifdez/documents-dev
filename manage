# PROFILE COMMANDS
# ════════════════════════════════════════════════════════════════════

# Internal: dump a single volume's contents into TMPDIR as <suffix>.tar
_dump_volume_to_tar() {
  local vol="$1" out_tar="$2"
  docker run --rm \
    -v "${vol}:/from:ro" \
    -v "$(dirname "$out_tar"):/out" \
    alpine sh -c "tar cf /out/$(basename "$out_tar") -C /from . 2>/dev/null" >/dev/null
}

# Internal: load a tar back into a (possibly new) volume
_load_tar_into_volume() {
  local in_tar="$1" vol="$2"
  docker volume create "$vol" >/dev/null
  docker run --rm \
    -v "${vol}:/to" \
    -v "$(dirname "$in_tar"):/in:ro" \
    alpine sh -c "tar xf /in/$(basename "$in_tar") -C /to" >/dev/null
}

# Internal: check whether services are running (by port/pid)
_services_are_running() {
  if [ -f "$PIDFILE" ]; then
    # shellcheck disable=SC1091
    source "$PIDFILE"
    if [ -n "${BACKEND_PID:-}" ] && kill -0 "${BACKEND_PID}" 2>/dev/null; then return 0; fi
    if [ -n "${MODELS_PID:-}" ] && kill -0 "${MODELS_PID}" 2>/dev/null; then return 0; fi
  fi
  pgrep -f "nest start" >/dev/null 2>&1 && return 0
  pgrep -f "python jobs.py" >/dev/null 2>&1 && return 0
  # Any container with our current project name?
  if [ -n "${COMPOSE_PROJECT_NAME:-}" ]; then
    if docker ps --format '{{.Names}}' | grep -q "^${COMPOSE_PROJECT_NAME}-"; then
      return 0
    fi
  fi
  return 1
}

cmd_profile_list() {
  detect_compose
  ensure_profiles_initialized
  local active
  active="$(get_active_profile)"

  printf "${BOLD}Profiles${NC}\n"
  printf "  %-2s %-20s %-10s %-10s %-10s %s\n" "" "NAME" "POSTGRES" "QDRANT" "NEO4J" "CREATED"
  printf "  %-2s %-20s %-10s %-10s %-10s %s\n" "" "----" "--------" "------" "-----" "-------"
  local p name created pg qd neo mark
  for p in "$PROFILES_DIR"/*/; do
    [ -d "$p" ] || continue
    name="$(basename "$p")"
    [ "$name" = "archived" ] && continue
    [ -f "$p/metadata.json" ] || continue
    created="$(grep -oE '"created_at"[[:space:]]*:[[:space:]]*"[^"]+"' "$p/metadata.json" | head -1 | cut -d'"' -f4 || echo "?")"
    pg="$(volume_size_human "$(profile_volume_name "$name" database-data)")"
    qd="$(volume_size_human "$(profile_volume_name "$name" qdrant_data)")"
    neo="$(volume_size_human "$(profile_volume_name "$name" neo4j_data)")"
    mark=" "
    [ "$name" = "$active" ] && mark="*"
    printf "  ${GREEN}%-2s${NC} %-20s %-10s %-10s %-10s %s\n" "$mark" "$name" "$pg" "$qd" "$neo" "$created"
  done

  # Archived profiles
  if [ -d "$PROFILES_DIR/archived" ]; then
    local any=0
    for a in "$PROFILES_DIR"/archived/*.tar.gz; do
      [ -f "$a" ] || continue
      if [ "$any" -eq 0 ]; then
        echo ""
        printf "${BOLD}Archived${NC}\n"
        printf "  %-20s %-10s %s\n" "NAME" "SIZE" "FILE"
        any=1
      fi
      local n sz
      n="$(basename "$a" .tar.gz)"
      sz="$(du -h "$a" 2>/dev/null | cut -f1)"
      printf "  %-20s %-10s %s\n" "$n" "$sz" "$a"
    done
  fi
}

cmd_profile_current() {
  ensure_profiles_initialized
  get_active_profile
}

cmd_profile_create() {
  local name="" src="" mode="empty"
  while [ $# -gt 0 ]; do
    case "$1" in
      --from)  src="$2"; mode="from"; shift 2 ;;
      --empty) mode="empty"; shift ;;
      -*)      fail "Unknown flag: $1" ;;
      *)       [ -z "$name" ] && name="$1" || fail "Unexpected argument: $1"; shift ;;
    esac
  done

  validate_profile_name "$name"
  detect_compose
  ensure_profiles_initialized

  profile_exists "$name"       && fail "Profile '$name' already exists."
  profile_archive_exists "$name" && fail "An archived profile named '$name' exists. Choose a different name or restore it first."

  if [ "$mode" = "from" ]; then
    [ "$src" = "current" ] && src="$(get_active_profile)"
    profile_exists "$src" || fail "Source profile '$src' does not exist."
    if [ "$src" = "$(get_active_profile)" ] && _services_are_running; then
      fail "Source '$src' is the active profile and services are running. Stop them first with './manage stop'."
    fi
  fi

  info "Creating profile '$name' (mode: $mode${src:+, from: $src})..."
  mkdir -p "$PROFILES_DIR/$name/documents" "$PROFILES_DIR/$name/documents-archive"

  if [ "$mode" = "from" ]; then
    # Clone documents
    info "  Cloning documents..."
    if [ -d "$PROFILES_DIR/$src/documents" ] && [ -n "$(ls -A "$PROFILES_DIR/$src/documents" 2>/dev/null || true)" ]; then
      (cd "$PROFILES_DIR/$src/documents" && tar cf - .) | (cd "$PROFILES_DIR/$name/documents" && tar xf -)
    fi
    # Clone archived documents (in-profile cold storage). Skip if user has overridden DOCUMENTS_ARCHIVE_DIR to an external path.
    if archive_dir_is_in_profile "$src" && [ -d "$PROFILES_DIR/$src/documents-archive" ] && [ -n "$(ls -A "$PROFILES_DIR/$src/documents-archive" 2>/dev/null || true)" ]; then
      info "  Cloning archived documents..."
      (cd "$PROFILES_DIR/$src/documents-archive" && tar cf - .) | (cd "$PROFILES_DIR/$name/documents-archive" && tar xf -)
    elif ! archive_dir_is_in_profile "$src"; then
      warn "  DOCUMENTS_ARCHIVE_DIR is set to an external path; archived files for '$src' are NOT cloned."
    fi
    # Clone volumes
    for suffix in database-data qdrant_data neo4j_data; do
      local src_vol dst_vol
      src_vol="$(profile_volume_name "$src" "$suffix")"
      dst_vol="$(profile_volume_name "$name" "$suffix")"
      if docker volume inspect "$src_vol" >/dev/null 2>&1; then
        info "  Cloning volume: $src_vol -> $dst_vol"
        clone_docker_volume "$src_vol" "$dst_vol"
      fi
    done
  fi

  cat > "$PROFILES_DIR/$name/metadata.json" <<METAEOF
{
  "name": "$name",
  "created_at": "$(date -Iseconds)",
  "description": "${mode} profile${src:+ cloned from $src}"
}
METAEOF

  ok "Profile '$name' created."
  echo ""
  echo "  Next steps:"
  echo "    ./manage profile:switch $name"
  echo "    ./manage start"
}

cmd_profile_clone() {
  local src="${1:-}" dst="${2:-}"
  [ -n "$src" ] && [ -n "$dst" ] || fail "Usage: $0 profile:clone <src> <dst>"
  cmd_profile_create "$dst" --from "$src"
}

cmd_profile_switch() {
  local target="${1:-}"
  validate_profile_name "$target"
  detect_compose
  ensure_profiles_initialized

  local current
  current="$(get_active_profile)"
  if [ "$target" = "$current" ]; then
    warn "'$target' is already the active profile."
    return 0
  fi

  if profile_archive_exists "$target" && ! profile_exists "$target"; then
    fail "Profile '$target' is archived. Restore it first: ./manage profile:restore $target"
  fi
  profile_exists "$target" || fail "Profile '$target' does not exist. Create it with: ./manage profile:create $target"

  # Stop whatever is running under the current profile
  export_compose_project
  if _services_are_running; then
    info "Stopping services on profile '$current'..."
    cmd_stop 2>/dev/null || true
  fi

  # Flip the active profile
  echo "$target" > "$PROFILES_DIR/.active"
  export_compose_project

  # Update documents symlink
  refresh_documents_symlink "$target"

  ok "Switched to profile: $target"
  echo ""
  echo "  Start services:  ./manage start"

  # Initialize DB if the target profile has no postgres volume yet
  if ! docker volume inspect "$(profile_volume_name "$target" database-data)" >/dev/null 2>&1; then
    init_db "$target"
  fi

  echo ""
  echo "  Start services:  ./manage start"
}

cmd_profile_delete() {
  local name="" yes=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes) yes=1; shift ;;
      -*)    fail "Unknown flag: $1" ;;
      *)     [ -z "$name" ] && name="$1" || fail "Unexpected argument: $1"; shift ;;
    esac
  done
  validate_profile_name "$name"
  detect_compose
  ensure_profiles_initialized

  profile_exists "$name" || fail "Profile '$name' does not exist."
  [ "$name" = "$(get_active_profile)" ] && fail "Cannot delete the active profile. Switch to another first."

  if [ "$yes" -ne 1 ]; then
    echo "This will PERMANENTLY DELETE profile '$name' (documents + volumes)."
    read -p "Type DELETE to continue: " confirm
    [ "$confirm" = "DELETE" ] || { echo "Aborted."; exit 1; }
  fi

  for suffix in database-data qdrant_data neo4j_data; do
    local vol
    vol="$(profile_volume_name "$name" "$suffix")"
    if docker volume inspect "$vol" >/dev/null 2>&1; then
      info "  Removing volume: $vol"
      docker volume rm "$vol" >/dev/null || warn "Could not remove $vol (in use?)"
    fi
  done
  rm -rf "$PROFILES_DIR/$name"
  ok "Profile '$name' deleted."
}

cmd_profile_rename() {
  local old="${1:-}" new="${2:-}"
  validate_profile_name "$old"
  validate_profile_name "$new"
  detect_compose
  ensure_profiles_initialized

  profile_exists "$old" || fail "Profile '$old' does not exist."
  profile_exists "$new" && fail "Profile '$new' already exists."

  if [ "$old" = "$(get_active_profile)" ] && _services_are_running; then
    fail "Cannot rename the active profile while services are running. Stop them first."
  fi

  info "Renaming profile: $old -> $new"
  # Rename volumes (must be done by create+copy+delete)
  for suffix in database-data qdrant_data neo4j_data; do
    local src_vol dst_vol
    src_vol="$(profile_volume_name "$old" "$suffix")"
    dst_vol="$(profile_volume_name "$new" "$suffix")"
    if docker volume inspect "$src_vol" >/dev/null 2>&1; then
      info "  Renaming volume: $src_vol -> $dst_vol"
      clone_docker_volume "$src_vol" "$dst_vol"
      docker volume rm "$src_vol" >/dev/null 2>&1 || warn "Could not remove $src_vol"
    fi
  done
  mv "$PROFILES_DIR/$old" "$PROFILES_DIR/$new"

  # Update metadata name
  if [ -f "$PROFILES_DIR/$new/metadata.json" ]; then
    sed -i "s/\"name\"[[:space:]]*:[[:space:]]*\"$old\"/\"name\": \"$new\"/" "$PROFILES_DIR/$new/metadata.json"
  fi

  # Update active pointer if needed
  if [ "$old" = "$(get_active_profile)" ]; then
    echo "$new" > "$PROFILES_DIR/.active"
    refresh_documents_symlink "$new"
  fi
  ok "Profile renamed to '$new'."
}

cmd_profile_archive() {
  local name="${1:-}"
  validate_profile_name "$name"
  detect_compose
  ensure_profiles_initialized

  profile_exists "$name" || fail "Profile '$name' does not exist."
  [ "$name" = "$(get_active_profile)" ] && fail "Cannot archive the active profile. Switch to another first."
  profile_archive_exists "$name" && fail "An archive already exists at .profiles/archived/${name}.tar.gz"

  info "Archiving profile '$name'..."
  local TMPDIR
  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' RETURN

  mkdir -p "$TMPDIR/documents" "$TMPDIR/documents-archive"
  if [ -d "$PROFILES_DIR/$name/documents" ] && [ -n "$(ls -A "$PROFILES_DIR/$name/documents" 2>/dev/null || true)" ]; then
    (cd "$PROFILES_DIR/$name/documents" && tar cf - .) | (cd "$TMPDIR/documents" && tar xf -)
  fi
  if archive_dir_is_in_profile "$name" && [ -d "$PROFILES_DIR/$name/documents-archive" ] && [ -n "$(ls -A "$PROFILES_DIR/$name/documents-archive" 2>/dev/null || true)" ]; then
    (cd "$PROFILES_DIR/$name/documents-archive" && tar cf - .) | (cd "$TMPDIR/documents-archive" && tar xf -)
  elif ! archive_dir_is_in_profile "$name"; then
    warn "DOCUMENTS_ARCHIVE_DIR is set to an external path; archived files for '$name' are NOT included in the archive."
    warn "Back up '$DOCUMENTS_ARCHIVE_DIR' separately if you want to preserve them."
  fi
  cp "$PROFILES_DIR/$name/metadata.json" "$TMPDIR/metadata.json" 2>/dev/null || true

  for suffix in database-data qdrant_data neo4j_data; do
    local vol
    vol="$(profile_volume_name "$name" "$suffix")"
    if docker volume inspect "$vol" >/dev/null 2>&1; then
      info "  Dumping volume: $vol"
      _dump_volume_to_tar "$vol" "$TMPDIR/${suffix}.tar"
    fi
  done

  mkdir -p "$PROFILES_DIR/archived"
  local out="$PROFILES_DIR/archived/${name}.tar.gz"
  info "  Compressing archive..."
  tar -czf "$out" -C "$TMPDIR" .

  # Remove live profile state
  for suffix in database-data qdrant_data neo4j_data; do
    local vol
    vol="$(profile_volume_name "$name" "$suffix")"
    docker volume rm "$vol" >/dev/null 2>&1 || true
  done
  rm -rf "$PROFILES_DIR/$name"

  ok "Profile '$name' archived to $out ($(du -h "$out" | cut -f1))"
}

cmd_profile_restore() {
  local name="${1:-}"
  validate_profile_name "$name"
  detect_compose
  ensure_profiles_initialized

  profile_archive_exists "$name" || fail "No archive found at .profiles/archived/${name}.tar.gz"
  profile_exists "$name" && fail "Profile '$name' already exists as a live profile."

  info "Restoring profile '$name'..."
  local TMPDIR
  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' RETURN

  tar -xzf "$PROFILES_DIR/archived/${name}.tar.gz" -C "$TMPDIR"

  mkdir -p "$PROFILES_DIR/$name/documents" "$PROFILES_DIR/$name/documents-archive"
  if [ -d "$TMPDIR/documents" ] && [ -n "$(ls -A "$TMPDIR/documents" 2>/dev/null || true)" ]; then
    (cd "$TMPDIR/documents" && tar cf - .) | (cd "$PROFILES_DIR/$name/documents" && tar xf -)
  fi
  if [ -d "$TMPDIR/documents-archive" ] && [ -n "$(ls -A "$TMPDIR/documents-archive" 2>/dev/null || true)" ]; then
    (cd "$TMPDIR/documents-archive" && tar cf - .) | (cd "$PROFILES_DIR/$name/documents-archive" && tar xf -)
  fi

  if [ -f "$TMPDIR/metadata.json" ]; then
    cp "$TMPDIR/metadata.json" "$PROFILES_DIR/$name/metadata.json"
  else
    cat > "$PROFILES_DIR/$name/metadata.json" <<METAEOF
{
  "name": "$name",
  "created_at": "$(date -Iseconds)",
  "description": "Restored from archive"
}
METAEOF
  fi

  for suffix in database-data qdrant_data neo4j_data; do
    if [ -f "$TMPDIR/${suffix}.tar" ]; then
      local vol
      vol="$(profile_volume_name "$name" "$suffix")"
      info "  Loading volume: $vol"
      _load_tar_into_volume "$TMPDIR/${suffix}.tar" "$vol"
    fi
  done

  rm -f "$PROFILES_DIR/archived/${name}.tar.gz"
  ok "Profile '$name' restored. Switch to it with: ./manage profile:switch $name"
}

# ════════════════════════════════════════════════════════════════════
# HELP
# ════════════════════════════════════════════════════════════════════
show_help() {
  cat <<EOF
Usage: $0 <command> [options]

Commands:
  install                 Set up the development environment:
                          - Download git submodules
                          - Configure root .env (database + qdrant)
                          - Start PostgreSQL + Qdrant (Docker)
                          - Run each submodule's install.sh

  start [components...]   Start services. With no args, starts everything:
                          - PostgreSQL + Qdrant (Docker)
                          - Backend (local, npm run start:dev)
                          - Models (local, python jobs.py in .venv)
                          With component names, only those are started:
                            ./manage start backend
                            ./manage start models database
                          Valid components: backend, models, database, qdrant, neo4j.

  stop [components...]    Stop services. With no args, stops everything (incl. docker).
                          With component names, only those are stopped (docker
                          infra stays up unless explicitly named):
                            ./manage stop backend
                            ./manage stop models qdrant

  reset [--yes]           Permanently delete all project data and re-initialize.
                          --yes  Skip confirmation prompt

  playground:start        Start the Jupyter playground (local .venv)

  playground:stop         Stop the Jupyter playground

  logs <service>          Tail logs for a service (backend, models, playground)

  export [output_file]    Create a compressed backup of the active profile's database and documents.

  import <backup_file>    Restore database and documents into the active profile.

  profile:list                         List all data profiles (live + archived).
  profile:current                      Print the name of the active profile.
  profile:create <name> [--from <src>|--empty]
                                       Create a new profile. --from <src|current> clones DB + documents
                                       from another profile; --empty (default) creates blank state.
  profile:clone <src> <dst>            Shortcut for 'profile:create <dst> --from <src>'.
  profile:switch <name>                Stop services and switch the active profile. Start again with 'start'.
  profile:rename <old> <new>           Rename a profile (requires services stopped if renaming the active one).
  profile:delete <name> [--yes]        Delete a profile (documents + volumes). Cannot delete the active one.
  profile:archive <name>               Pack a profile into .profiles/archived/<name>.tar.gz (and remove live state).
  profile:restore <name>               Unpack an archived profile back into live state.

  help                    Show this help message.

Notes:
  Each profile has two file stores:
    - documents/          Hot storage (active resource files).
    - documents-archive/  Cold storage (resources archived from the app's UI).

  By default, both live inside .profiles/<profile>/. Override the cold store
  with the env var DOCUMENTS_ARCHIVE_DIR to point to a slower/cheaper mount
  (HDD, NAS, S3 mount, ...). When DOCUMENTS_ARCHIVE_DIR is external, the
  profile commands above (archive, restore, export, import, reset) will
  NOT touch it — back it up separately if needed.
EOF
}

# ════════════════════════════════════════════════════════════════════
# MAIN
# ════════════════════════════════════════════════════════════════════
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  install)            cmd_install "$@" ;;
  start)              cmd_start "$@" ;;
  stop)               cmd_stop "$@" ;;
  reset)              cmd_reset "$@" ;;
  playground:start)   cmd_playground_start "$@" ;;
  playground:stop)    cmd_playground_stop "$@" ;;
  logs)               cmd_logs "$@" ;;
  export)             cmd_export "$@" ;;
  import)             cmd_import "$@" ;;
  profile:list)       cmd_profile_list "$@" ;;
  profile:current)    cmd_profile_current "$@" ;;
  profile:create)     cmd_profile_create "$@" ;;
  profile:clone)      cmd_profile_clone "$@" ;;
  profile:switch)     cmd_profile_switch "$@" ;;
  profile:rename)     cmd_profile_rename "$@" ;;
  profile:delete)     cmd_profile_delete "$@" ;;
  profile:archive)    cmd_profile_archive "$@" ;;
  profile:restore)    cmd_profile_restore "$@" ;;
  help|--help|-h) show_help ;;
  *) fail "Unknown command: $COMMAND. Run '$0 help' for usage." ;;
esac
