#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

# ── Interactive prompt with default value ────────────────────────
# Usage: ask "Variable description" "DEFAULT_VALUE"
# Sets REPLY to the user's answer (or default if empty)
ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

# ── Interactive .env setup ───────────────────────────────────────
setup_env_root() {
  local ENV_FILE="$ROOT_DIR/.env"
  if [ -f "$ENV_FILE" ]; then
    ok ".env already exists (skipping)"
    return
  fi

  echo ""
  printf "${BOLD}${CYAN}── Root environment configuration ──${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  ask "PostgreSQL host" "localhost";            local PG_HOST="$REPLY"
  ask "PostgreSQL port" "5432";                 local PG_PORT="$REPLY"
  ask "PostgreSQL database" "documents";        local PG_DB="$REPLY"
  ask "PostgreSQL user" "postgres";             local PG_USER="$REPLY"
  ask "PostgreSQL password" "example";          local PG_PASS="$REPLY"
  ask "Enable AI / RAG feature (true/false)" "true"; local RAG_ENABLED="$REPLY"

  local QD_HOST="localhost" QD_PORT="6333"
  if [ "$RAG_ENABLED" != "false" ]; then
    ask "Qdrant host" "localhost";                QD_HOST="$REPLY"
    ask "Qdrant port" "6333";                     QD_PORT="$REPLY"
  fi

  cat > "$ENV_FILE" <<EOF
# Database
POSTGRES_HOST=$PG_HOST
POSTGRES_PORT=$PG_PORT
POSTGRES_DB=$PG_DB
POSTGRES_USER=$PG_USER
POSTGRES_PASSWORD=$PG_PASS

# Qdrant
QDRANT_HOST=$QD_HOST
QDRANT_PORT=$QD_PORT
EOF
  ok "Created .env"
}

# ── Load .env if present (export vars for docker-compose and scripts) ──
load_env() {
  if [ -f "$ROOT_DIR/.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "$ROOT_DIR/.env"
    set +a
  fi
}

# ── Check if RAG feature is enabled ──────────────────────────
is_rag_enabled() {
  local backend_env="$ROOT_DIR/backend/.env"
  if [ -f "$backend_env" ]; then
    local val
    val=$(grep -E '^FEATURE_RAG=' "$backend_env" 2>/dev/null | cut -d= -f2)
    [ "$val" != "false" ]
  else
    return 0  # Default: enabled
  fi
}

# Returns the docker compose services to start
get_compose_services() {
  if is_rag_enabled; then
    echo ""  # empty = all services
  else
    echo "database"
  fi
}

# ── Data profiles (versioned DB + documents) ────────────────────────
PROFILES_DIR="$ROOT_DIR/.profiles"

get_active_profile() {
  if [ -f "$PROFILES_DIR/.active" ]; then
    tr -d '[:space:]' < "$PROFILES_DIR/.active"
  else
    echo "default"
  fi
}

# Build the COMPOSE_PROJECT_NAME for a given profile
profile_project_name() {
  echo "documents-dev-$1"
}

# Build a Docker volume name for a given profile + volume suffix
profile_volume_name() {
  echo "documents-dev-$1_$2"
}

# Export COMPOSE_PROJECT_NAME so every `docker compose` call is namespaced by profile
export_compose_project() {
  export COMPOSE_PROJECT_NAME="$(profile_project_name "$(get_active_profile)")"
}

profile_exists() {
  [ -d "$PROFILES_DIR/$1" ] && [ -f "$PROFILES_DIR/$1/metadata.json" ]
}

profile_archive_exists() {
  [ -f "$PROFILES_DIR/archived/$1.tar.gz" ]
}

validate_profile_name() {
  local name="$1"
  if [ -z "$name" ]; then
    fail "Profile name is required."
  fi
  if ! [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]]; then
    fail "Invalid profile name '$name' (allowed: letters, digits, '-', '_'; must not start with '-' or '_')."
  fi
}

# Copy one Docker volume into another (creates destination if missing).
# Args: <src_volume> <dst_volume>
clone_docker_volume() {
  local src="$1" dst="$2"
  if ! docker volume inspect "$src" >/dev/null 2>&1; then
    return 0
  fi
  docker volume create "$dst" >/dev/null
  docker run --rm \
    -v "${src}:/from:ro" \
    -v "${dst}:/to" \
    alpine sh -c 'cd /from && (tar cf - . | (cd /to && tar xf -))' >/dev/null
}

# Human-readable size of a Docker volume (or "-" if absent)
volume_size_human() {
  local vol="$1"
  if ! docker volume inspect "$vol" >/dev/null 2>&1; then
    echo "-"
    return
  fi
  docker run --rm -v "${vol}:/v:ro" alpine sh -c 'du -sh /v 2>/dev/null | cut -f1' 2>/dev/null || echo "?"
}

# Ensure the documents/ entry is a symlink to the active profile's folder
refresh_documents_symlink() {
  local profile="$1"
  local target_rel=".profiles/${profile}/documents"
  local target_abs="$PROFILES_DIR/${profile}/documents"
  mkdir -p "$target_abs"

  if [ -L "$ROOT_DIR/documents" ]; then
    rm -f "$ROOT_DIR/documents"
  elif [ -d "$ROOT_DIR/documents" ]; then
    if [ -z "$(ls -A "$ROOT_DIR/documents" 2>/dev/null || true)" ]; then
      rmdir "$ROOT_DIR/documents"
    else
      fail "documents/ exists as a real directory with content. Move it into .profiles/<profile>/documents/ manually before continuing."
    fi
  fi
  ln -s "$target_rel" "$ROOT_DIR/documents"

  # Symmetric symlink for the archive folder (cold storage for archived resources)
  local archive_target_rel=".profiles/${profile}/documents-archive"
  local archive_target_abs="$PROFILES_DIR/${profile}/documents-archive"
  mkdir -p "$archive_target_abs"

  if [ -L "$ROOT_DIR/documents-archive" ]; then
    rm -f "$ROOT_DIR/documents-archive"
  elif [ -d "$ROOT_DIR/documents-archive" ]; then
    if [ -z "$(ls -A "$ROOT_DIR/documents-archive" 2>/dev/null || true)" ]; then
      rmdir "$ROOT_DIR/documents-archive"
    else
      fail "documents-archive/ exists as a real directory with content. Move it into .profiles/<profile>/documents-archive/ manually before continuing."
    fi
  fi
  ln -s "$archive_target_rel" "$ROOT_DIR/documents-archive"
}

# Returns 0 if DOCUMENTS_ARCHIVE_DIR points inside the profile (default), 1 if it's external.
# When external, the manage profile commands won't include archived files in the bundle.
archive_dir_is_in_profile() {
  local profile="$1"
  if [ -z "${DOCUMENTS_ARCHIVE_DIR:-}" ]; then
    return 0
  fi
  local in_profile_abs configured_abs
  in_profile_abs="$(cd "$PROFILES_DIR/${profile}" 2>/dev/null && pwd)/documents-archive"
  configured_abs="$(realpath -m "$DOCUMENTS_ARCHIVE_DIR" 2>/dev/null || echo "$DOCUMENTS_ARCHIVE_DIR")"
  [ "$in_profile_abs" = "$configured_abs" ]
}

# Migrate pre-profile state (legacy volumes + plain documents/ dir) into a 'default' profile.
# Idempotent; no-op once .profiles/.active exists.
ensure_profiles_initialized() {
  if [ -f "$PROFILES_DIR/.active" ]; then
    return 0
  fi

  info "Initializing data profile system..."
  mkdir -p "$PROFILES_DIR/default" "$PROFILES_DIR/default/documents-archive" "$PROFILES_DIR/archived"

  # Move any existing documents into the default profile
  if [ -d "$ROOT_DIR/documents" ] && [ ! -L "$ROOT_DIR/documents" ]; then
    mkdir -p "$PROFILES_DIR/default/documents"
    if [ -n "$(ls -A "$ROOT_DIR/documents" 2>/dev/null || true)" ]; then
      info "  Moving existing documents/ into .profiles/default/documents/"
      (cd "$ROOT_DIR/documents" && tar cf - .) | (cd "$PROFILES_DIR/default/documents" && tar xf -)
      rm -rf "$ROOT_DIR/documents"/*
      find "$ROOT_DIR/documents" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
    fi
    rmdir "$ROOT_DIR/documents" 2>/dev/null || rm -rf "$ROOT_DIR/documents"
  fi

  # Stop any containers left from the pre-profile layout (container_name: database/qdrant/neo4j)
  for c in database qdrant neo4j; do
    if docker ps -a --format '{{.Names}}' | grep -qx "$c"; then
      info "  Removing legacy container: $c"
      docker rm -f "$c" >/dev/null 2>&1 || true
    fi
  done

  # Rename legacy volumes (documents-dev_*) to the new profile-scoped names
  for suffix in database-data qdrant_data neo4j_data; do
    local legacy="documents-dev_${suffix}"
    local target="$(profile_volume_name default "$suffix")"
    if docker volume inspect "$legacy" >/dev/null 2>&1 && ! docker volume inspect "$target" >/dev/null 2>&1; then
      info "  Migrating volume: $legacy -> $target"
      clone_docker_volume "$legacy" "$target"
      docker volume rm "$legacy" >/dev/null 2>&1 || warn "Could not remove legacy volume $legacy"
    fi
  done

  # Write metadata for default profile
  cat > "$PROFILES_DIR/default/metadata.json" <<METAEOF
{
  "name": "default",
  "created_at": "$(date -Iseconds)",
  "description": "Initial profile (auto-created during profile system init)"
}
METAEOF

  # Recreate documents/ as a symlink
  refresh_documents_symlink default

  echo "default" > "$PROFILES_DIR/.active"
  ok "Profile system ready. Active profile: default"
}

PIDFILE="$ROOT_DIR/.pids"
LOCKFILE="$ROOT_DIR/.manage.lock"
LOG_DIR="$ROOT_DIR/.logs"
MAX_LOG_BACKUPS=3
MAX_LOG_SIZE=$((10 * 1024 * 1024))  # 10MB per log file
LOG_CHECK_INTERVAL=60                # check every 60 seconds

# ── Kill all processes matching a pattern (thorough cleanup) ──
kill_by_pattern() {
  local pattern="$1" label="${2:-process}"
  local pids
  pids=$(pgrep -f "$pattern" 2>/dev/null || true)
  if [ -n "$pids" ]; then
    echo "$pids" | xargs -r kill 2>/dev/null || true
    sleep 0.5
    # Force kill any survivors
    pids=$(pgrep -f "$pattern" 2>/dev/null || true)
    if [ -n "$pids" ]; then
      echo "$pids" | xargs -r kill -9 2>/dev/null || true
    fi
    ok "Killed $label processes"
    return 0
  fi
  return 1
}

# ── Kill process group started with setsid ──
kill_process_group() {
  local pid="$1"
  if [ -z "$pid" ]; then return 1; fi
  if ! kill -0 "$pid" 2>/dev/null; then return 1; fi
  # Negative PID sends signal to entire process group
  kill -- -"$pid" 2>/dev/null || true
  sleep 0.5
  kill -9 -- -"$pid" 2>/dev/null || true
  return 0
}

# ── Guard: check if a service is already running ──
is_service_running() {
  local name="$1" pid_var="$2"
  if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    local pid="${!pid_var:-}"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0  # running
    fi
  fi
  # Also check by process pattern as fallback
  case "$name" in
    backend) pgrep -f "nest start" >/dev/null 2>&1 && return 0 ;;
    models)  pgrep -f "python jobs.py" >/dev/null 2>&1 && return 0 ;;
  esac
  return 1  # not running
}

# ── Log rotation (copytruncate — safe while process is writing) ──
rotate_log() {
  local logfile="$1"
  if [ ! -f "$logfile" ]; then return; fi
  local size
  size=$(stat -c%s "$logfile" 2>/dev/null || echo 0)
  if [ "$size" -gt 0 ]; then
    local base
    base=$(basename "$logfile")
    local ts
    ts=$(date +%Y%m%d_%H%M%S)
    # Copy then truncate — keeps the file descriptor valid for the running process
    cp "$logfile" "${LOG_DIR}/${base}.${ts}"
    : > "$logfile"
    # Keep only the last N backups
    ls -t "${LOG_DIR}/${base}."* 2>/dev/null | tail -n +$((MAX_LOG_BACKUPS + 1)) | xargs -r rm -f
  fi
}

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

# ── Live log rotation watchdog (runs in background) ──
start_log_watchdog() {
  ensure_log_dir
  (
    while true; do
      sleep "$LOG_CHECK_INTERVAL"
      for logfile in "$ROOT_DIR"/.backend.log "$ROOT_DIR"/.models.log "$ROOT_DIR"/.playground.log; do
        if [ -f "$logfile" ]; then
          size=$(stat -c%s "$logfile" 2>/dev/null || echo 0)
          if [ "$size" -gt "$MAX_LOG_SIZE" ]; then
            rotate_log "$logfile"
          fi
        fi
      done
    done
  ) &
  LOG_WATCHDOG_PID=$!
}

# ── Detect Docker Compose ──────────────────────────────────────────
detect_compose() {
  command -v docker >/dev/null 2>&1 || fail "Docker is not installed."
  if docker compose version >/dev/null 2>&1; then
    COMPOSE_CMD="docker compose"
  elif docker-compose version >/dev/null 2>&1; then
    COMPOSE_CMD="docker-compose"
  else
    fail "Docker Compose not found (requires 'docker compose' or 'docker-compose')."
  fi
}

# ── Wait for PostgreSQL ────────────────────────────────────────────
wait_for_postgres() {
  local retries=${1:-30}
  info "Waiting for PostgreSQL..."
  until $COMPOSE_CMD exec -T database pg_isready -U "${POSTGRES_USER:-postgres}" >/dev/null 2>&1; do
    retries=$((retries - 1))
    if [ "$retries" -le 0 ]; then
      fail "PostgreSQL did not become ready in time."
    fi
    sleep 1
  done
  ok "PostgreSQL is ready"
}

# ── Ensure PostgreSQL extensions ───────────────────────────────────
ensure_pg_extensions() {
  info "Ensuring PostgreSQL extensions..."
  $COMPOSE_CMD exec -T database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "CREATE EXTENSION IF NOT EXISTS pg_trgm; CREATE EXTENSION IF NOT EXISTS unaccent;" >/dev/null 2>&1
  ok "PostgreSQL extensions ready (pg_trgm, unaccent)"
}

# ── Initialize DB: migrations + features (for a fresh profile) ────
init_db() {
  local profile="${1:-$(get_active_profile)}"
  info "Initializing database for profile '$profile'..."

  # Ensure COMPOSE_PROJECT_NAME targets the right profile
  local prev_project="${COMPOSE_PROJECT_NAME:-}"
  export COMPOSE_PROJECT_NAME="$(profile_project_name "$profile")"

  start_docker_service database

  info "Running migrations..."
  (cd "$ROOT_DIR/backend" && npm run migration:run 2>&1 | grep -E "successfully|failed|Error") || fail "Migrations failed."
  ok "Migrations complete"

  info "Installing features..."
  local db_container
  db_container="$(profile_project_name "$profile")-database-1"
  for feature in authors bibliography calendar canvas datasets data-sources entities knowledge_base notes tasks timelines; do
    local sql_file="$ROOT_DIR/backend/features/$feature/install.sql"
    if [ -f "$sql_file" ]; then
      docker exec -i "$db_container" psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" < "$sql_file" > /dev/null 2>&1 || warn "Feature '$feature' had warnings (usually safe to ignore)"
    fi
  done
  ok "Features installed"

  export COMPOSE_PROJECT_NAME="$prev_project"
}

# ════════════════════════════════════════════════════════════════════
# INSTALL
# ════════════════════════════════════════════════════════════════════
cmd_install() {
  detect_compose
  load_env

  if ! docker info >/dev/null 2>&1; then
    fail "Docker daemon is not running. Start Docker and try again."
  fi

  ok "Docker and Docker Compose available"

  # ── Initialize and update git submodules ──
  info "Downloading submodules..."
  git submodule update --init --recursive
  ok "Submodules ready"

  # ── Interactive root environment configuration ──
  info "Configuring root environment..."
  setup_env_root

  # Reload env so docker-compose and scripts use the configured values
  load_env

  # ── Initialize profile system (default profile + documents symlink) ──
  ensure_profiles_initialized
  export_compose_project
  ok "documents/ symlink points to profile: $(get_active_profile)"

  # ── Start infrastructure (database + conditionally qdrant) ──
  info "Starting infrastructure containers..."
  $COMPOSE_CMD up -d database
  wait_for_postgres 30
  ensure_pg_extensions

  # ── Install each submodule (each handles its own .env + deps) ──
  info "Installing backend service..."
  cd "$ROOT_DIR/backend"
  bash install
  cd "$ROOT_DIR"

  # Start Qdrant only if RAG is enabled (checked after backend .env is created)
  if is_rag_enabled; then
    info "RAG enabled – starting Qdrant..."
    $COMPOSE_CMD up -d qdrant
    ok "Qdrant started"
  else
    info "RAG disabled – skipping Qdrant"
  fi

  info "Installing models service..."
  cd "$ROOT_DIR/models"
  bash install
  cd "$ROOT_DIR"

  info "Installing frontend..."
  cd "$ROOT_DIR/frontend"
  bash install
  cd "$ROOT_DIR"

  # ── Summary ──
  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  Installation complete!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  echo "  Start all services:    bash manage.sh start"
  echo "  Stop all services:     bash manage.sh stop"
  echo ""
  echo "  Or run individually:"
  echo "    Infrastructure:      docker compose up -d"
  echo "    Backend:             cd backend && npm run start:dev"
  echo "    Models:              cd models && source .venv/bin/activate && python jobs.py"
  echo "    Frontend:            cd frontend && npm start"
  echo ""
}

# ════════════════════════════════════════════════════════════════════
# START
# ════════════════════════════════════════════════════════════════════
save_pidfile() {
  echo "BACKEND_PID=${BACKEND_PID:-}" > "$PIDFILE"
  echo "MODELS_PID=${MODELS_PID:-}" >> "$PIDFILE"
  echo "LOG_WATCHDOG_PID=${LOG_WATCHDOG_PID:-}" >> "$PIDFILE"
}

source_pidfile() {
  BACKEND_PID="" ; MODELS_PID="" ; LOG_WATCHDOG_PID=""
  if [ -f "$PIDFILE" ]; then source "$PIDFILE"; fi
}

ensure_log_watchdog() {
  source_pidfile
  if [ -n "${LOG_WATCHDOG_PID:-}" ] && kill -0 "${LOG_WATCHDOG_PID}" 2>/dev/null; then
    return 0
  fi
  ensure_log_dir
  start_log_watchdog
  save_pidfile
  ok "Log watchdog started (rotates at ${MAX_LOG_SIZE} bytes, checks every ${LOG_CHECK_INTERVAL}s)"
}

start_backend() {
  source_pidfile
  if is_service_running backend BACKEND_PID; then
    warn "Backend is already running. Skipping."
    return 0
  fi
  ensure_log_dir
  rotate_log "$ROOT_DIR/.backend.log"
  kill_by_pattern "nest start" "backend orphan" 2>/dev/null || true
  kill_by_pattern "ts-node.*nest" "backend ts-node orphan" 2>/dev/null || true
  info "Starting backend..."
  cd "$ROOT_DIR/backend"
  setsid npm run start:dev > "$ROOT_DIR/.backend.log" 2>&1 &
  BACKEND_PID=$!
  cd "$ROOT_DIR"
  ok "Backend started (PGID: $BACKEND_PID)"
  save_pidfile
}

start_models() {
  source_pidfile
  if is_service_running models MODELS_PID; then
    warn "Models is already running. Skipping."
    return 0
  fi
  ensure_log_dir
  rotate_log "$ROOT_DIR/.models.log"
  kill_by_pattern "python jobs.py" "models orphan" 2>/dev/null || true
  info "Starting models..."
  cd "$ROOT_DIR/models"
  source .venv/bin/activate
  setsid python jobs.py > "$ROOT_DIR/.models.log" 2>&1 &
  MODELS_PID=$!
  deactivate
  cd "$ROOT_DIR"
  ok "Models started (PGID: $MODELS_PID)"
  save_pidfile
}

start_docker_service() {
  local svc="$1"
  detect_compose
  info "Starting docker service: $svc..."
  $COMPOSE_CMD up -d "$svc"
  if [ "$svc" = "database" ]; then
    wait_for_postgres 30
    ensure_pg_extensions
  fi
}

stop_backend() {
  source_pidfile
  if [ -n "${BACKEND_PID:-}" ] && kill_process_group "${BACKEND_PID}"; then
    ok "Backend process group stopped (PGID: ${BACKEND_PID})"
  fi
  BACKEND_PID=""
  save_pidfile
  kill_by_pattern "nest start" "backend orphan" 2>/dev/null || true
  kill_by_pattern "ts-node.*nest" "backend ts-node orphan" 2>/dev/null || true
  local port_pid
  port_pid=$(lsof -ti:3000 2>/dev/null || true)
  if [ -n "$port_pid" ]; then
    echo "$port_pid" | xargs -r kill -9 2>/dev/null || true
    ok "Killed process(es) on port 3000"
  fi
}

stop_models() {
  source_pidfile
  if [ -n "${MODELS_PID:-}" ] && kill_process_group "${MODELS_PID}"; then
    ok "Models process group stopped (PGID: ${MODELS_PID})"
  fi
  MODELS_PID=""
  save_pidfile
  kill_by_pattern "python jobs.py" "models orphan" 2>/dev/null || true
}

stop_docker_service() {
  local svc="$1"
  detect_compose
  info "Stopping docker service: $svc..."
  $COMPOSE_CMD stop "$svc"
}

is_known_component() {
  case "$1" in
    backend|models|database|qdrant|neo4j) return 0 ;;
    *) return 1 ;;
  esac
}

print_start_summary() {
  source_pidfile
  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  Services are running!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  if [ -n "${BACKEND_PID:-}" ]; then
    echo "  Backend API:    http://localhost:3000  (PID: $BACKEND_PID)"
  fi
  if [ -n "${MODELS_PID:-}" ]; then
    echo "  Models:         running                (PID: $MODELS_PID)"
  fi
  echo "  PostgreSQL:     localhost:5432"
  if is_rag_enabled; then
    echo "  Qdrant:         http://localhost:6333"
  fi
  echo ""
  echo "  Logs:"
  echo "    Backend:      tail -f .backend.log"
  echo "    Models:       tail -f .models.log"
  echo ""
  echo "  Stop:           ./manage stop"
  echo ""
}

cmd_start() {
  detect_compose
  load_env
  ensure_profiles_initialized
  export_compose_project
  info "Active profile: $(get_active_profile)"

  # Per-component start
  if [ $# -gt 0 ]; then
    for component in "$@"; do
      is_known_component "$component" || fail "Unknown component '$component' (valid: backend, models, database, qdrant, neo4j)"
    done
    for component in "$@"; do
      case "$component" in
        backend)
          start_docker_service database
          if is_rag_enabled; then start_docker_service qdrant; fi
          ensure_log_watchdog
          start_backend
          ;;
        models)
          ensure_log_watchdog
          start_models
          ;;
        database|qdrant|neo4j)
          start_docker_service "$component"
          ;;
      esac
    done
    print_start_summary
    return 0
  fi

  # ── Full start (no args): existing behaviour ──
  local backend_already=0 models_already=0
  if is_service_running backend BACKEND_PID; then
    warn "Backend is already running. Skipping."
    backend_already=1
  fi
  if is_service_running models MODELS_PID; then
    warn "Models is already running. Skipping."
    models_already=1
  fi
  if [ "$backend_already" -eq 1 ] && [ "$models_already" -eq 1 ]; then
    warn "All services are already running. Use './manage stop' first to restart."
    return 0
  fi

  if is_rag_enabled; then
    info "Starting database and qdrant..."
    $COMPOSE_CMD up -d
  else
    info "Starting database (RAG disabled, skipping qdrant)..."
    $COMPOSE_CMD up -d database
  fi
  wait_for_postgres 30
  ensure_pg_extensions

  ensure_log_watchdog

  if [ "$backend_already" -eq 0 ]; then start_backend; fi
  if [ "$models_already" -eq 0 ]; then start_models; fi

  print_start_summary
}

# ════════════════════════════════════════════════════════════════════
# STOP
# ════════════════════════════════════════════════════════════════════
cmd_stop() {
  detect_compose
  load_env
  ensure_profiles_initialized
  export_compose_project

  # Per-component stop (don't tear down docker infra unless explicitly named)
  if [ $# -gt 0 ]; then
    for component in "$@"; do
      is_known_component "$component" || fail "Unknown component '$component' (valid: backend, models, database, qdrant, neo4j)"
    done
    for component in "$@"; do
      case "$component" in
        backend) stop_backend ;;
        models)  stop_models ;;
        database|qdrant|neo4j) stop_docker_service "$component" ;;
      esac
    done
    echo ""
    ok "Requested services stopped"
    return 0
  fi

  # ── Full stop (no args): existing behaviour ──
  if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    if kill_process_group "${BACKEND_PID:-}"; then
      ok "Backend process group stopped (PGID: ${BACKEND_PID})"
    fi
    if kill_process_group "${MODELS_PID:-}"; then
      ok "Models process group stopped (PGID: ${MODELS_PID})"
    fi
    if [ -n "${LOG_WATCHDOG_PID:-}" ] && kill -0 "${LOG_WATCHDOG_PID}" 2>/dev/null; then
      kill "${LOG_WATCHDOG_PID}" 2>/dev/null || true
      ok "Log watchdog stopped"
    fi
    rm -f "$PIDFILE"
  else
    warn "No PID file found."
  fi

  kill_by_pattern "nest start" "backend orphan" 2>/dev/null || true
  kill_by_pattern "ts-node.*nest" "backend ts-node orphan" 2>/dev/null || true
  kill_by_pattern "python jobs.py" "models orphan" 2>/dev/null || true

  local port_pid
  port_pid=$(lsof -ti:3000 2>/dev/null || true)
  if [ -n "$port_pid" ]; then
    echo "$port_pid" | xargs -r kill -9 2>/dev/null || true
    ok "Killed process(es) on port 3000"
  fi

  info "Stopping database and qdrant..."
  $COMPOSE_CMD down
  ok "Infrastructure stopped"

  echo ""
  ok "All services stopped"
}

# ════════════════════════════════════════════════════════════════════
# RESET
# ════════════════════════════════════════════════════════════════════
cmd_reset() {
  local YES=0
  for arg in "$@"; do
    case "$arg" in
      --yes) YES=1 ;;
      *) ;;
    esac
  done

  if [ "$YES" -ne 1 ]; then
    echo "This will PERMANENTLY DELETE project data (documents, DB tables, Qdrant collections, frontend settings)."
    read -p "Type RESET to continue: " confirm
    if [ "$confirm" != "RESET" ]; then
      echo "Aborted."
      exit 1
    fi
  fi

  detect_compose
  load_env
  ensure_profiles_initialized
  export_compose_project
  echo "==> Reset started (profile: $(get_active_profile))"

  # ── Stop local services if running ──
  cmd_stop 2>/dev/null || true

  # ── Start infrastructure ──
  echo "-- Starting database and qdrant containers"
  $COMPOSE_CMD up -d
  wait_for_postgres 30

  # ── Drop database ──
  echo "-- Dropping all tables"
  $COMPOSE_CMD exec -T database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"

  # ── Remove document files (of the active profile) ──
  local docs_target="$PROFILES_DIR/$(get_active_profile)/documents"
  echo "-- Removing document files in $docs_target"
  if [ -d "$docs_target" ]; then
    rm -rf "$docs_target"/* 2>/dev/null || true
    find "$docs_target" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
  fi

  local archive_target="$PROFILES_DIR/$(get_active_profile)/documents-archive"
  echo "-- Removing archived document files in $archive_target"
  if [ -d "$archive_target" ]; then
    rm -rf "$archive_target"/* 2>/dev/null || true
    find "$archive_target" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
  fi
  if ! archive_dir_is_in_profile "$(get_active_profile)"; then
    warn "DOCUMENTS_ARCHIVE_DIR is set to an external path; files at '$DOCUMENTS_ARCHIVE_DIR' were NOT removed."
  fi

  # ── Clear Qdrant ──
  echo "-- Clearing all Qdrant collections"
  if command -v curl >/dev/null 2>&1; then
    collections_json="$(curl -sS http://localhost:6333/collections || echo '')"
    if [ -n "$collections_json" ]; then
      names=$(printf "%s" "$collections_json" | python3 -c 'import sys,json; r=json.load(sys.stdin); print("\n".join([c["name"] for c in r.get("collections",[])]))' 2>/dev/null || true)
      if [ -n "$names" ]; then
        while IFS= read -r name; do
          [ -z "$name" ] && continue
          echo "Deleting collection: $name"
          curl -sS -X DELETE "http://localhost:6333/collections/$name" || true
        done <<< "$names"
      fi
    fi
  fi

  # ── Remove frontend settings ──
  echo "-- Removing frontend user settings"
  CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/documents-frontend"
  if [ -d "$CFG_DIR" ]; then
    rm -rf "$CFG_DIR"
  fi

  # ── Run migrations ──
  echo "-- Running migrations"
  cd "$ROOT_DIR/backend"
  npm run migration:run

  # ── Install features ──
  echo "-- Installing features"
  npm run feature:install
  cd "$ROOT_DIR"

  echo "==> Reset completed successfully"
}

# ════════════════════════════════════════════════════════════════════
# PLAYGROUND START
# ════════════════════════════════════════════════════════════════════
cmd_playground_start() {
  local PLAYGROUND_DIR="$ROOT_DIR/playground"

  if [ ! -d "$PLAYGROUND_DIR" ]; then
    fail "playground/ directory not found."
  fi

  # ── Create .venv if missing ──
  cd "$PLAYGROUND_DIR"
  if [ ! -d ".venv" ]; then
    info "Creating Python virtual environment for playground..."
    python3 -m venv .venv
    ok "Created .venv at playground/.venv"

    info "Installing playground dependencies (this may take a while)..."
    source .venv/bin/activate
    pip install --upgrade pip
    pip install -r requirements.txt
    deactivate
    ok "Playground dependencies installed"
  fi

  # ── Start Jupyter ──
  ensure_log_dir
  rotate_log "$ROOT_DIR/.playground.log"
  info "Starting Jupyter notebook..."
  source .venv/bin/activate
  jupyter notebook > "$ROOT_DIR/.playground.log" 2>&1 &
  PLAYGROUND_PID=$!
  deactivate
  cd "$ROOT_DIR"

  # ── Save PID ──
  echo "PLAYGROUND_PID=$PLAYGROUND_PID" > "$ROOT_DIR/.playground.pid"

  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  Playground is running!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  echo "  Jupyter:   http://localhost:8888  (PID: $PLAYGROUND_PID)"
  echo "  Log:       tail -f .playground.log"
  echo ""
  echo "  Stop:      bash manage.sh playground:stop"
  echo ""
}

# ════════════════════════════════════════════════════════════════════
# PLAYGROUND STOP
# ════════════════════════════════════════════════════════════════════
cmd_playground_stop() {
  local PGPIDFILE="$ROOT_DIR/.playground.pid"

  if [ -f "$PGPIDFILE" ]; then
    source "$PGPIDFILE"
    if [ -n "${PLAYGROUND_PID:-}" ] && kill -0 "$PLAYGROUND_PID" 2>/dev/null; then
      kill "$PLAYGROUND_PID" 2>/dev/null || true
      ok "Playground stopped (PID: $PLAYGROUND_PID)"
    else
      warn "Playground process (PID: ${PLAYGROUND_PID:-?}) is not running."
    fi
    rm -f "$PGPIDFILE"
  else
    warn "No playground PID file found. Trying to find process..."
    pkill -f "jupyter-notebook" 2>/dev/null && ok "Jupyter process killed" || warn "No jupyter process found."
  fi
}

# ════════════════════════════════════════════════════════════════════
# LOGS
# ════════════════════════════════════════════════════════════════════
cmd_logs() {
  local SERVICE="${1:-}"
  local LOGFILE

  case "$SERVICE" in
    backend)    LOGFILE="$ROOT_DIR/.backend.log" ;;
    models)     LOGFILE="$ROOT_DIR/.models.log" ;;
    playground) LOGFILE="$ROOT_DIR/.playground.log" ;;
    *)          fail "Usage: $0 logs <backend|models|playground>" ;;
