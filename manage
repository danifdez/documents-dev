#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

# ── Interactive prompt with default value ────────────────────────
# Usage: ask "Variable description" "DEFAULT_VALUE"
# Sets REPLY to the user's answer (or default if empty)
ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

# ── Interactive .env setup ───────────────────────────────────────
setup_env_root() {
  local ENV_FILE="$ROOT_DIR/.env"
  if [ -f "$ENV_FILE" ]; then
    ok ".env already exists (skipping)"
    return
  fi

  echo ""
  printf "${BOLD}${CYAN}── Root environment configuration ──${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  ask "PostgreSQL host" "localhost";            local PG_HOST="$REPLY"
  ask "PostgreSQL port" "5432";                 local PG_PORT="$REPLY"
  ask "PostgreSQL database" "documents";        local PG_DB="$REPLY"
  ask "PostgreSQL user" "postgres";             local PG_USER="$REPLY"
  ask "PostgreSQL password" "example";          local PG_PASS="$REPLY"
  ask "Enable authentication (true/false)" "false"; local AUTH="$REPLY"
  ask "JWT secret" "change-me-in-production";   local JWT="$REPLY"
  ask "Enable offline support (true/false)" "false"; local OFFLINE="$REPLY"
  ask "Offline file size limit (bytes)" "10485760"; local OFFLINE_LIMIT="$REPLY"

  cat > "$ENV_FILE" <<EOF
# Database
POSTGRES_HOST=$PG_HOST
POSTGRES_PORT=$PG_PORT
POSTGRES_DB=$PG_DB
POSTGRES_USER=$PG_USER
POSTGRES_PASSWORD=$PG_PASS

# Authentication (set AUTH_ENABLED=true for multi-user mode)
AUTH_ENABLED=$AUTH
JWT_SECRET=$JWT

# Offline support (set OFFLINE_ENABLED=true to allow clients to cache content)
OFFLINE_ENABLED=$OFFLINE
OFFLINE_FILE_SIZE_LIMIT=$OFFLINE_LIMIT
EOF
  ok "Created .env"

  # Export shared values for child env setups
  ENV_PG_HOST="$PG_HOST"
  ENV_PG_PORT="$PG_PORT"
  ENV_PG_DB="$PG_DB"
  ENV_PG_USER="$PG_USER"
  ENV_PG_PASS="$PG_PASS"
  ENV_AUTH="$AUTH"
  ENV_JWT="$JWT"
  ENV_OFFLINE="$OFFLINE"
  ENV_OFFLINE_LIMIT="$OFFLINE_LIMIT"
}

setup_env_backend() {
  local ENV_FILE="$ROOT_DIR/backend/.env"
  if [ -f "$ENV_FILE" ]; then
    ok "backend/.env already exists (skipping)"
    return
  fi

  # Use values from root setup if available, otherwise use defaults
  local DEF_PG_HOST="${ENV_PG_HOST:-localhost}"
  local DEF_PG_PORT="${ENV_PG_PORT:-5432}"
  local DEF_PG_DB="${ENV_PG_DB:-documents}"
  local DEF_PG_USER="${ENV_PG_USER:-postgres}"
  local DEF_PG_PASS="${ENV_PG_PASS:-example}"
  local DEF_AUTH="${ENV_AUTH:-false}"
  local DEF_JWT="${ENV_JWT:-change-me-in-production}"
  local DEF_OFFLINE="${ENV_OFFLINE:-false}"
  local DEF_OFFLINE_LIMIT="${ENV_OFFLINE_LIMIT:-10485760}"

  echo ""
  printf "${BOLD}${CYAN}── Backend environment configuration ──${NC}\n"
  printf "${DIM}  Values from root config are used as defaults where applicable.${NC}\n"
  echo ""

  ask "Backend server port" "3000";                   local PORT="$REPLY"
  ask "CORS origin" "http://localhost:5173";           local CORS="$REPLY"
  ask "Body size limit" "50mb";                        local BODY="$REPLY"
  ask "Documents storage directory" "../documents";    local STORAGE="$REPLY"
  ask "JWT access token expiry" "15m";                 local JWT_ACCESS="$REPLY"
  ask "JWT refresh token expiry" "7d";                 local JWT_REFRESH="$REPLY"
  ask "Default admin username" "admin";                local ADMIN_USER="$REPLY"
  ask "Default admin password" "admin";                local ADMIN_PASS="$REPLY"

  cat > "$ENV_FILE" <<EOF
# Database
POSTGRES_HOST=$DEF_PG_HOST
POSTGRES_PORT=$DEF_PG_PORT
POSTGRES_DB=$DEF_PG_DB
POSTGRES_USER=$DEF_PG_USER
POSTGRES_PASSWORD=$DEF_PG_PASS

# Server
