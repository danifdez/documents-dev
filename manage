  ask "Background hours start (0-23)" "2";            local BG_START="$REPLY"
  ask "Background hours end (0-23)" "6";              local BG_END="$REPLY"
  ask "Documents storage directory" "../documents";   local STORAGE="$REPLY"

  cat > "$ENV_FILE" <<EOF
