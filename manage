setup_env_frontend() {
  local ENV_FILE="$ROOT_DIR/frontend/.env"
  if [ -f "$ENV_FILE" ]; then
    ok "frontend/.env already exists (skipping)"
    return
  fi

  echo ""
  printf "${BOLD}${CYAN}── Frontend environment configuration ──${NC}\n"
  echo ""

  ask "Backend API URL" "http://localhost:3000"; local API_URL="$REPLY"

  cat > "$ENV_FILE" <<EOF
VITE_API_URL=$API_URL
EOF
  ok "Created frontend/.env"
}

# ── Load .env if present (export vars for docker-compose and scripts) ──
load_env() {
  if [ -f "$ROOT_DIR/.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "$ROOT_DIR/.env"
    set +a
  fi
}

PIDFILE="$ROOT_DIR/.pids"
LOCKFILE="$ROOT_DIR/.manage.lock"
LOG_DIR="$ROOT_DIR/.logs"
MAX_LOG_BACKUPS=3
MAX_LOG_SIZE=$((10 * 1024 * 1024))  # 10MB per log file
LOG_CHECK_INTERVAL=60                # check every 60 seconds

# ── Kill all processes matching a pattern (thorough cleanup) ──
kill_by_pattern() {
  local pattern="$1" label="${2:-process}"
  local pids
  pids=$(pgrep -f "$pattern" 2>/dev/null || true)
  if [ -n "$pids" ]; then
    echo "$pids" | xargs -r kill 2>/dev/null || true
    sleep 0.5
    # Force kill any survivors
    pids=$(pgrep -f "$pattern" 2>/dev/null || true)
    if [ -n "$pids" ]; then
      echo "$pids" | xargs -r kill -9 2>/dev/null || true
    fi
    ok "Killed $label processes"
    return 0
  fi
  return 1
}

# ── Kill process group started with setsid ──
kill_process_group() {
  local pid="$1"
  if [ -z "$pid" ]; then return 1; fi
  if ! kill -0 "$pid" 2>/dev/null; then return 1; fi
  # Negative PID sends signal to entire process group
  kill -- -"$pid" 2>/dev/null || true
  sleep 0.5
  kill -9 -- -"$pid" 2>/dev/null || true
  return 0
}

# ── Guard: check if a service is already running ──
is_service_running() {
  local name="$1" pid_var="$2"
  if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    local pid="${!pid_var:-}"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0  # running
    fi
  fi
  # Also check by process pattern as fallback
  case "$name" in
    backend) pgrep -f "nest start" >/dev/null 2>&1 && return 0 ;;
    models)  pgrep -f "python jobs.py" >/dev/null 2>&1 && return 0 ;;
  esac
  return 1  # not running
}

# ── Log rotation (copytruncate — safe while process is writing) ──
rotate_log() {
  local logfile="$1"
  if [ ! -f "$logfile" ]; then return; fi
  local size
  size=$(stat -c%s "$logfile" 2>/dev/null || echo 0)
  if [ "$size" -gt 0 ]; then
    local base
    base=$(basename "$logfile")
    local ts
    ts=$(date +%Y%m%d_%H%M%S)
    # Copy then truncate — keeps the file descriptor valid for the running process
    cp "$logfile" "${LOG_DIR}/${base}.${ts}"
    : > "$logfile"
    # Keep only the last N backups
    ls -t "${LOG_DIR}/${base}."* 2>/dev/null | tail -n +$((MAX_LOG_BACKUPS + 1)) | xargs -r rm -f
  fi
}

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

# ── Live log rotation watchdog (runs in background) ──
start_log_watchdog() {
  ensure_log_dir
  (
    while true; do
      sleep "$LOG_CHECK_INTERVAL"
      for logfile in "$ROOT_DIR"/.backend.log "$ROOT_DIR"/.models.log "$ROOT_DIR"/.playground.log; do
        if [ -f "$logfile" ]; then
          size=$(stat -c%s "$logfile" 2>/dev/null || echo 0)
          if [ "$size" -gt "$MAX_LOG_SIZE" ]; then
            rotate_log "$logfile"
          fi
        fi
      done
    done
  ) &
  LOG_WATCHDOG_PID=$!
}

# ── Detect Docker Compose ──────────────────────────────────────────
detect_compose() {
  command -v docker >/dev/null 2>&1 || fail "Docker is not installed."
  if docker compose version >/dev/null 2>&1; then
    COMPOSE_CMD="docker compose"
  elif docker-compose version >/dev/null 2>&1; then
    COMPOSE_CMD="docker-compose"
  else
    fail "Docker Compose not found (requires 'docker compose' or 'docker-compose')."
  fi
}

# ── Wait for PostgreSQL ────────────────────────────────────────────
wait_for_postgres() {
  local retries=${1:-30}
  info "Waiting for PostgreSQL..."
  until docker exec database pg_isready -U "${POSTGRES_USER:-postgres}" >/dev/null 2>&1; do
    retries=$((retries - 1))
    if [ "$retries" -le 0 ]; then
      fail "PostgreSQL did not become ready in time."
    fi
    sleep 1
  done
  ok "PostgreSQL is ready"
}

# ── Ensure PostgreSQL extensions ───────────────────────────────────
ensure_pg_extensions() {
  info "Ensuring PostgreSQL extensions..."
  docker exec database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "CREATE EXTENSION IF NOT EXISTS pg_trgm; CREATE EXTENSION IF NOT EXISTS unaccent;" >/dev/null 2>&1
  ok "PostgreSQL extensions ready (pg_trgm, unaccent)"
}

# ════════════════════════════════════════════════════════════════════
# INSTALL
# ════════════════════════════════════════════════════════════════════
cmd_install() {
  detect_compose
  load_env

  if ! docker info >/dev/null 2>&1; then
    fail "Docker daemon is not running. Start Docker and try again."
  fi

  ok "Docker and Docker Compose available"

  # ── Interactive environment configuration ──
  info "Configuring environment..."
  setup_env_root
  setup_env_backend
  setup_env_models
  setup_env_frontend

  # Reload env so docker-compose and scripts use the configured values
  load_env

  # ── Create documents directory ──
  mkdir -p "$ROOT_DIR/documents"
  ok "documents/ directory ready"

  # ── Start infrastructure (database + qdrant) ──
  info "Starting database and qdrant containers..."
  $COMPOSE_CMD up -d
  wait_for_postgres 30
  ensure_pg_extensions

  # ── Install backend via its install script ──
  info "Installing backend service..."
  cd "$ROOT_DIR/backend"
  bash install.sh
  cd "$ROOT_DIR"

  # ── Install models via its install script ──
  info "Installing models service..."
  cd "$ROOT_DIR/models"
  bash install.sh
  cd "$ROOT_DIR"

  # ── Install frontend dependencies ──
  info "Installing frontend dependencies..."
  cd "$ROOT_DIR/frontend"
  npm install
  ok "Frontend dependencies installed"

  # ── Install rpmbuild if missing (needed by electron-forge maker-rpm) ──
  if ! command -v rpmbuild >/dev/null 2>&1; then
    info "Installing rpmbuild (required for electron-forge RPM builds)..."
    sudo apt-get update -qq && sudo apt-get install -y -qq rpm
    ok "rpmbuild installed"
  else
    ok "rpmbuild already available"
  fi
  cd "$ROOT_DIR"

  # ── Summary ──
  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  Installation complete!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  echo "  Start all services:    bash manage.sh start"
  echo "  Stop all services:     bash manage.sh stop"
  echo ""
  echo "  Or run individually:"
  echo "    Infrastructure:      docker compose up -d"
  echo "    Backend:             cd backend && npm run start:dev"
  echo "    Models:              cd models && source .venv/bin/activate && python jobs.py"
  echo "    Frontend:            cd frontend && npm start"
  echo ""
}

# ════════════════════════════════════════════════════════════════════
# START
# ════════════════════════════════════════════════════════════════════
cmd_start() {
  detect_compose
  load_env

  # ── Check for already-running instances ──
  local backend_already=0 models_already=0
  if is_service_running backend BACKEND_PID; then
    warn "Backend is already running. Skipping."
    backend_already=1
  fi
  if is_service_running models MODELS_PID; then
    warn "Models is already running. Skipping."
    models_already=1
  fi
  if [ "$backend_already" -eq 1 ] && [ "$models_already" -eq 1 ]; then
    warn "All services are already running. Use 'bash manage.sh stop' first to restart."
    return 0
  fi

  # ── Start infrastructure ──
  info "Starting database and qdrant..."
  $COMPOSE_CMD up -d
  wait_for_postgres 30
  ensure_pg_extensions

  # ── Rotate old logs and start watchdog ──
  ensure_log_dir
  rotate_log "$ROOT_DIR/.backend.log"
  rotate_log "$ROOT_DIR/.models.log"
  start_log_watchdog
  ok "Log watchdog started (rotates at ${MAX_LOG_SIZE} bytes, checks every ${LOG_CHECK_INTERVAL}s)"

  # ── Preserve existing PIDs from file ──
  local EXISTING_BACKEND_PID="" EXISTING_MODELS_PID=""
  if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    EXISTING_BACKEND_PID="${BACKEND_PID:-}"
    EXISTING_MODELS_PID="${MODELS_PID:-}"
  fi

  # ── Start backend (only if not already running) ──
  if [ "$backend_already" -eq 0 ]; then
    # Kill any orphan backend processes first
    kill_by_pattern "nest start" "backend orphan" 2>/dev/null || true
    kill_by_pattern "ts-node.*nest" "backend ts-node orphan" 2>/dev/null || true
    info "Starting backend..."
    cd "$ROOT_DIR/backend"
    setsid npm run start:dev > "$ROOT_DIR/.backend.log" 2>&1 &
    BACKEND_PID=$!
    cd "$ROOT_DIR"
    ok "Backend started (PGID: $BACKEND_PID)"
  else
    BACKEND_PID="$EXISTING_BACKEND_PID"
  fi

  # ── Start models (only if not already running) ──
  if [ "$models_already" -eq 0 ]; then
    # Kill any orphan models processes first
    kill_by_pattern "python jobs.py" "models orphan" 2>/dev/null || true
    info "Starting models..."
    cd "$ROOT_DIR/models"
    source .venv/bin/activate
    setsid python jobs.py > "$ROOT_DIR/.models.log" 2>&1 &
    MODELS_PID=$!
    deactivate
    cd "$ROOT_DIR"
    ok "Models started (PGID: $MODELS_PID)"
  else
    MODELS_PID="$EXISTING_MODELS_PID"
  fi

  # ── Save PIDs ──
  echo "BACKEND_PID=$BACKEND_PID" > "$PIDFILE"
  echo "MODELS_PID=$MODELS_PID" >> "$PIDFILE"
  echo "LOG_WATCHDOG_PID=$LOG_WATCHDOG_PID" >> "$PIDFILE"

  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  All services are running!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  echo "  Backend API:    http://localhost:3000  (PID: $BACKEND_PID)"
  echo "  Models:         running                (PID: $MODELS_PID)"
  echo "  PostgreSQL:     localhost:5432"
  echo "  Qdrant:         http://localhost:6333"
  echo ""
  echo "  Logs:"
  echo "    Backend:      tail -f .backend.log"
  echo "    Models:       tail -f .models.log"
  echo ""
  echo "  Frontend (run separately):"
  echo "    cd frontend && npm start"
  echo ""
  echo "  Stop:           bash manage.sh stop"
  echo ""
}

# ════════════════════════════════════════════════════════════════════
# STOP
# ════════════════════════════════════════════════════════════════════
cmd_stop() {
  detect_compose

  # ── Kill tracked process groups ──
  if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    if kill_process_group "${BACKEND_PID:-}"; then
      ok "Backend process group stopped (PGID: ${BACKEND_PID})"
    fi
    if kill_process_group "${MODELS_PID:-}"; then
      ok "Models process group stopped (PGID: ${MODELS_PID})"
    fi
    if [ -n "${LOG_WATCHDOG_PID:-}" ] && kill -0 "${LOG_WATCHDOG_PID}" 2>/dev/null; then
      kill "${LOG_WATCHDOG_PID}" 2>/dev/null || true
      ok "Log watchdog stopped"
    fi
    rm -f "$PIDFILE"
  else
    warn "No PID file found."
  fi

  # ── Always clean up any orphan processes by pattern ──
  kill_by_pattern "nest start" "backend orphan" 2>/dev/null || true
  kill_by_pattern "ts-node.*nest" "backend ts-node orphan" 2>/dev/null || true
  kill_by_pattern "python jobs.py" "models orphan" 2>/dev/null || true

  # ── Kill anything still on port 3000 ──
  local port_pid
  port_pid=$(lsof -ti:3000 2>/dev/null || true)
  if [ -n "$port_pid" ]; then
    echo "$port_pid" | xargs -r kill -9 2>/dev/null || true
    ok "Killed process(es) on port 3000"
  fi

  # ── Stop Docker containers ──
  info "Stopping database and qdrant..."
  $COMPOSE_CMD down
  ok "Infrastructure stopped"

  echo ""
  ok "All services stopped"
}

# ════════════════════════════════════════════════════════════════════
# RESET
# ════════════════════════════════════════════════════════════════════
cmd_reset() {
  local YES=0
  for arg in "$@"; do
    case "$arg" in
      --yes) YES=1 ;;
      *) ;;
    esac
  done

  if [ "$YES" -ne 1 ]; then
    echo "This will PERMANENTLY DELETE project data (documents, DB tables, Qdrant collections, frontend settings)."
    read -p "Type RESET to continue: " confirm
    if [ "$confirm" != "RESET" ]; then
      echo "Aborted."
      exit 1
    fi
  fi

  detect_compose
  load_env
  echo "==> Reset started"

  # ── Stop local services if running ──
  cmd_stop 2>/dev/null || true

  # ── Start infrastructure ──
  echo "-- Starting database and qdrant containers"
  $COMPOSE_CMD up -d
  wait_for_postgres 30

  # ── Drop database ──
  echo "-- Dropping all tables"
  docker exec database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"

  # ── Remove document files ──
  echo "-- Removing document files in ./documents"
  if [ -d "$ROOT_DIR/documents" ]; then
    rm -rf "$ROOT_DIR/documents"/* || true
  fi

  # ── Clear Qdrant ──
  echo "-- Clearing all Qdrant collections"
  if command -v curl >/dev/null 2>&1; then
    collections_json="$(curl -sS http://localhost:6333/collections || echo '')"
    if [ -n "$collections_json" ]; then
      names=$(printf "%s" "$collections_json" | python3 -c 'import sys,json; r=json.load(sys.stdin); print("\n".join([c["name"] for c in r.get("collections",[])]))' 2>/dev/null || true)
      if [ -n "$names" ]; then
        while IFS= read -r name; do
          [ -z "$name" ] && continue
          echo "Deleting collection: $name"
          curl -sS -X DELETE "http://localhost:6333/collections/$name" || true
        done <<< "$names"
      fi
    fi
  fi

  # ── Remove frontend settings ──
  echo "-- Removing frontend user settings"
  CFG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/documents-frontend"
  if [ -d "$CFG_DIR" ]; then
    rm -rf "$CFG_DIR"
  fi

  # ── Run migrations ──
  echo "-- Running migrations"
  cd "$ROOT_DIR/backend"
  npm run migration:run
  cd "$ROOT_DIR"

  echo "==> Reset completed successfully"
}

# ════════════════════════════════════════════════════════════════════
# PLAYGROUND START
# ════════════════════════════════════════════════════════════════════
cmd_playground_start() {
  local PLAYGROUND_DIR="$ROOT_DIR/playground"

  if [ ! -d "$PLAYGROUND_DIR" ]; then
    fail "playground/ directory not found."
  fi

  # ── Create .venv if missing ──
  cd "$PLAYGROUND_DIR"
  if [ ! -d ".venv" ]; then
    info "Creating Python virtual environment for playground..."
    python3 -m venv .venv
    ok "Created .venv at playground/.venv"

    info "Installing playground dependencies (this may take a while)..."
    source .venv/bin/activate
    pip install --upgrade pip
    pip install -r requirements.txt
    deactivate
    ok "Playground dependencies installed"
  fi

  # ── Start Jupyter ──
  ensure_log_dir
  rotate_log "$ROOT_DIR/.playground.log"
  info "Starting Jupyter notebook..."
  source .venv/bin/activate
  jupyter notebook > "$ROOT_DIR/.playground.log" 2>&1 &
  PLAYGROUND_PID=$!
  deactivate
  cd "$ROOT_DIR"

  # ── Save PID ──
  echo "PLAYGROUND_PID=$PLAYGROUND_PID" > "$ROOT_DIR/.playground.pid"

  echo ""
  printf "${GREEN}============================================${NC}\n"
  printf "${GREEN}  Playground is running!${NC}\n"
  printf "${GREEN}============================================${NC}\n"
  echo ""
  echo "  Jupyter:   http://localhost:8888  (PID: $PLAYGROUND_PID)"
  echo "  Log:       tail -f .playground.log"
  echo ""
  echo "  Stop:      bash manage.sh playground:stop"
  echo ""
}

# ════════════════════════════════════════════════════════════════════
# PLAYGROUND STOP
# ════════════════════════════════════════════════════════════════════
cmd_playground_stop() {
  local PGPIDFILE="$ROOT_DIR/.playground.pid"

  if [ -f "$PGPIDFILE" ]; then
    source "$PGPIDFILE"
    if [ -n "${PLAYGROUND_PID:-}" ] && kill -0 "$PLAYGROUND_PID" 2>/dev/null; then
      kill "$PLAYGROUND_PID" 2>/dev/null || true
      ok "Playground stopped (PID: $PLAYGROUND_PID)"
    else
      warn "Playground process (PID: ${PLAYGROUND_PID:-?}) is not running."
    fi
    rm -f "$PGPIDFILE"
  else
    warn "No playground PID file found. Trying to find process..."
    pkill -f "jupyter-notebook" 2>/dev/null && ok "Jupyter process killed" || warn "No jupyter process found."
  fi
}

# ════════════════════════════════════════════════════════════════════
# LOGS
# ════════════════════════════════════════════════════════════════════
cmd_logs() {
  local SERVICE="${1:-}"
  local LOGFILE

  case "$SERVICE" in
    backend)    LOGFILE="$ROOT_DIR/.backend.log" ;;
    models)     LOGFILE="$ROOT_DIR/.models.log" ;;
    playground) LOGFILE="$ROOT_DIR/.playground.log" ;;
    *)          fail "Usage: $0 logs <backend|models|playground>" ;;
  esac

  [ -f "$LOGFILE" ] || fail "Log file not found: $LOGFILE. Is the service running?"
  tail -f "$LOGFILE"
}

# ════════════════════════════════════════════════════════════════════
# EXPORT
# ════════════════════════════════════════════════════════════════════
cmd_export() {
  local OUTPUT_FILE="${1:-}"
  local TIMESTAMP
  TIMESTAMP="$(date +%Y%m%d_%H%M%S)"

  if [ -z "$OUTPUT_FILE" ]; then
    OUTPUT_FILE="$ROOT_DIR/backup_${TIMESTAMP}.tar.gz"
  fi

  case "$OUTPUT_FILE" in
    /*) ;;
    *) OUTPUT_FILE="$ROOT_DIR/$OUTPUT_FILE" ;;
  esac

  load_env
  info "Starting export..."

  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT

  # ── Dump PostgreSQL ──
  info "Dumping PostgreSQL database..."
  PGPASSWORD="${POSTGRES_PASSWORD:-example}" pg_dump -h localhost -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" --clean --if-exists > "$TMPDIR/database.sql"
  ok "Database dump complete"

  # ── Copy documents ──
  if [ -d "$ROOT_DIR/documents" ] && [ "$(ls -A "$ROOT_DIR/documents" 2>/dev/null)" ]; then
    info "Copying documents folder..."
    cp -a "$ROOT_DIR/documents" "$TMPDIR/documents"
    ok "Documents copied"
  else
    mkdir -p "$TMPDIR/documents"
  fi

  # ── Metadata ──
  cat > "$TMPDIR/backup_metadata.json" <<METAEOF
{
  "created_at": "$(date -Iseconds)",
  "hostname": "$(hostname)",
  "user": "$(whoami)"
}
METAEOF

  # ── Compress ──
  info "Compressing backup..."
  tar -czf "$OUTPUT_FILE" -C "$TMPDIR" database.sql documents backup_metadata.json

  ok "Export complete: $OUTPUT_FILE ($(du -h "$OUTPUT_FILE" | cut -f1))"
}

# ════════════════════════════════════════════════════════════════════
# IMPORT
# ════════════════════════════════════════════════════════════════════
cmd_import() {
  local INPUT_FILE="${1:-}"

  if [ -z "$INPUT_FILE" ]; then
    fail "Usage: $0 import <backup_file.tar.gz>"
  fi

  case "$INPUT_FILE" in
    /*) ;;
    *) INPUT_FILE="$(pwd)/$INPUT_FILE" ;;
  esac

  [ -f "$INPUT_FILE" ] || fail "File not found: $INPUT_FILE"

  echo "This will REPLACE the current database and documents with the contents of:"
  echo "  $INPUT_FILE"
  read -p "Type IMPORT to continue: " confirm
  if [ "$confirm" != "IMPORT" ]; then
    echo "Aborted."
    exit 1
  fi

  detect_compose
  load_env
  info "Starting import..."

  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT

  info "Extracting backup..."
  tar -xzf "$INPUT_FILE" -C "$TMPDIR"

  [ -f "$TMPDIR/database.sql" ] || fail "Invalid backup: database.sql not found"
  [ -d "$TMPDIR/documents" ]    || fail "Invalid backup: documents/ not found"

  # ── Ensure infrastructure is running ──
  $COMPOSE_CMD up -d
  wait_for_postgres 30

  # ── Stop local services ──
  cmd_stop 2>/dev/null || true
  $COMPOSE_CMD up -d

  # ── Restore PostgreSQL ──
  info "Restoring PostgreSQL database..."
  docker exec database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" -c "DROP SCHEMA public CASCADE; CREATE SCHEMA public;"
  docker exec -i database psql -U "${POSTGRES_USER:-postgres}" -d "${POSTGRES_DB:-documents}" < "$TMPDIR/database.sql"
  ok "Database restored"

  # ── Restore documents ──
  info "Restoring documents folder..."
  rm -rf "$ROOT_DIR/documents"/* 2>/dev/null || true
  if [ "$(ls -A "$TMPDIR/documents" 2>/dev/null)" ]; then
    cp -a "$TMPDIR/documents"/. "$ROOT_DIR/documents/"
  fi
  ok "Documents restored"

  ok "Import complete. Run 'bash manage.sh start' to start services."
}

# ════════════════════════════════════════════════════════════════════
# HELP
# ════════════════════════════════════════════════════════════════════
show_help() {
  cat <<EOF
Usage: $0 <command> [options]

Commands:
  install                 Set up the development environment:
                          - Start PostgreSQL + Qdrant (Docker)
                          - Install backend deps + run migrations
                          - Create Python .venv + install deps
                          - Install frontend deps

  start                   Start all services:
                          - PostgreSQL + Qdrant (Docker)
                          - Backend (local, npm run start:dev)
                          - Models (local, python jobs.py in .venv)

  stop                    Stop all services

  reset [--yes]           Permanently delete all project data and re-initialize.
                          --yes  Skip confirmation prompt

  playground:start        Start the Jupyter playground (local .venv)

  playground:stop         Stop the Jupyter playground

  logs <service>          Tail logs for a service (backend, models, playground)

  export [output_file]    Create a compressed backup of the database and documents.

  import <backup_file>    Restore database and documents from a backup file.

  help                    Show this help message.
EOF
}

# ════════════════════════════════════════════════════════════════════
# MAIN
# ════════════════════════════════════════════════════════════════════
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  install)            cmd_install "$@" ;;
  start)              cmd_start "$@" ;;
  stop)               cmd_stop "$@" ;;
  reset)              cmd_reset "$@" ;;
  playground:start)   cmd_playground_start "$@" ;;
  playground:stop)    cmd_playground_stop "$@" ;;
  logs)               cmd_logs "$@" ;;
  export)             cmd_export "$@" ;;
  import)             cmd_import "$@" ;;
  help|--help|-h) show_help ;;
  *) fail "Unknown command: $COMMAND. Run '$0 help' for usage." ;;
esac
