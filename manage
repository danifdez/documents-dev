JWT_SECRET=$DEF_JWT
JWT_ACCESS_EXPIRY=$JWT_ACCESS
JWT_REFRESH_EXPIRY=$JWT_REFRESH
ADMIN_USERNAME=$ADMIN_USER
ADMIN_PASSWORD=$ADMIN_PASS

# Offline support (set OFFLINE_ENABLED=true to allow clients to cache content)
OFFLINE_ENABLED=$DEF_OFFLINE
OFFLINE_FILE_SIZE_LIMIT=$DEF_OFFLINE_LIMIT
EOF
  ok "Created backend/.env"
}

